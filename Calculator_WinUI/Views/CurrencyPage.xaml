<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Calculator_WinUI.Views.CurrencyPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Calculator_WinUI.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Border Background="{StaticResource Brush_Layer3}">
        <Grid Margin="5">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="5*" />
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!--<Button Grid.Row="0"
                    Grid.Column="0"
                    Margin="2"
                    Height="40"
                    Width="45"
                    HorizontalAlignment="Left"
                    Click="MenuClick"
                    Style="{StaticResource Style_ButtonLayer3_5}">
                <Button.Resources>
                    <StaticResource x:Key="ButtonBackgroundPointerOver"
                                    ResourceKey="Brush_Layer4_5" />
                    <StaticResource x:Key="ButtonBorderBrushPointerOver"
                                    ResourceKey="Brush_Layer4_5" />
                    <StaticResource x:Key="ButtonBackgroundPressed"
                                    ResourceKey="Brush_Layer4" />
                    <StaticResource x:Key="ButtonBorderBrushPressed"
                                    ResourceKey="Brush_Layer4" />
                </Button.Resources>
                <StackPanel>
                    <Image Source="ms-appx:///Assets/Icons/menu.png"
                           Height="25"
                           Width="25" />
                </StackPanel>
            </Button>-->

            <!--  header  -->
            <Grid
                Grid.Row="0"
                Grid.ColumnSpan="4"
                Height="38"
                Margin="45,0,0,0"
                Background="Transparent">
                <StackPanel
                    HorizontalAlignment="Left"
                    Orientation="Horizontal"
                    Spacing="8">

                    <TextBlock
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Style="{ThemeResource SubtitleTextBlockStyle}"
                        Text="Standard" />

                    <Button
                        Width="32"
                        Height="32"
                        Padding="0"
                        Style="{ThemeResource SubtleButtonStyle}">
                        <FontIcon FontSize="16" Glyph="&#xE81C;" />
                    </Button>
                </StackPanel>

                <Button
                    Width="32"
                    Height="32"
                    Padding="0"
                    HorizontalAlignment="Right"
                    Style="{ThemeResource SubtleButtonStyle}">
                    <FontIcon FontSize="16" Glyph="&#xE8A7;" />
                </Button>
            </Grid>

            <!--  currency selection 1  -->
            <Button
                Grid.Row="1"
                Grid.Column="0"
                Grid.ColumnSpan="3"
                Margin="2"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Right"
                Click="Click_SelectionCurrency1"
                Style="{ThemeResource SubtleButtonStyle}">
                <TextBlock
                    x:Name="TextBlock_SelectedCurrency1"
                    Margin="0,0,7,0"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Style="{ThemeResource CaptionTextBlockStyle}"
                    Text="Europe-Euro" />
            </Button>

            <ScrollViewer
                Grid.Row="2"
                Grid.Column="0"
                Grid.ColumnSpan="3"
                Margin="2"
                HorizontalScrollBarVisibility="Visible"
                VerticalScrollBarVisibility="Disabled">
                <TextBlock
                    x:Name="TextBlock_Currency1"
                    Margin="5,-3,5,0"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Style="{ThemeResource TitleLargeTextBlockStyle}"
                    Text="0" />
            </ScrollViewer>

            <!--  currency selection 2  -->
            <Button
                Grid.Row="3"
                Grid.Column="0"
                Grid.ColumnSpan="3"
                Margin="2"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Right"
                Click="Click_SelectionCurrency2"
                Style="{ThemeResource SubtleButtonStyle}">
                <TextBlock
                    x:Name="TextBlock_SelectedCurrency2"
                    Margin="0,0,7,0"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Style="{ThemeResource CaptionTextBlockStyle}"
                    Text="United States-Dollar" />
            </Button>

            <ScrollViewer
                Grid.Row="4"
                Grid.Column="0"
                Grid.ColumnSpan="3"
                Margin="2"
                HorizontalScrollBarVisibility="Visible"
                VerticalScrollBarVisibility="Disabled">
                <TextBlock
                    x:Name="TextBlock_Currency2"
                    Margin="5,-3,5,0"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Style="{ThemeResource TitleLargeTextBlockStyle}"
                    Text="0" />
            </ScrollViewer>

            <!--  currency rate display  -->
            <Border
                Grid.Row="5"
                Grid.Column="0"
                Grid.ColumnSpan="3"
                Margin="2"
                Background="{StaticResource Brush_Layer3}">
                <TextBlock
                    x:Name="TextBlock_CurrencyRate"
                    Margin="0,0,7,0"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                    Style="{StaticResource Font_SelectionButton}"
                    Text="1 EUR = 1.08 USD" />
            </Border>

            <!--  input buttons  -->
            <Grid
                Grid.Row="6"
                Grid.Column="0"
                Grid.ColumnSpan="3"
                ColumnSpacing="4"
                RowSpacing="4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Button
                    Grid.Row="0"
                    Grid.Column="0"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Click="Click_Refresh"
                    Style="{StaticResource OperatorButtonStyle}">
                    <FontIcon FontSize="16" Glyph="&#xE895;" />
                </Button>
                <Button
                    Grid.Row="0"
                    Grid.Column="1"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Click="Click_ClearAllInput"
                    Style="{StaticResource OperatorButtonStyle}">
                    <TextBlock Style="{ThemeResource BodyLargeTextBlockStyle}" Text="CE" />
                </Button>
                <Button
                    Grid.Row="0"
                    Grid.Column="2"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Click="Click_Backspace"
                    Style="{StaticResource OperatorButtonStyle}">
                    <FontIcon FontSize="16" Glyph="&#xE8A7;" />
                </Button>

                <Button
                    Grid.Row="1"
                    Grid.Column="0"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Click="Click_Seven"
                    Style="{StaticResource NumberPadButtonStyle}">
                    <TextBlock Style="{ThemeResource BodyLargeTextBlockStyle}" Text="7" />
                </Button>
                <Button
                    Grid.Row="1"
                    Grid.Column="1"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Click="Click_Eight"
                    Style="{StaticResource NumberPadButtonStyle}">
                    <TextBlock Style="{ThemeResource BodyLargeTextBlockStyle}" Text="8" />
                </Button>
                <Button
                    Grid.Row="1"
                    Grid.Column="2"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Click="Click_Nine"
                    Style="{StaticResource NumberPadButtonStyle}">
                    <TextBlock Style="{ThemeResource BodyLargeTextBlockStyle}" Text="9" />
                </Button>

                <Button
                    Grid.Row="2"
                    Grid.Column="0"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Click="Click_Four"
                    Style="{StaticResource NumberPadButtonStyle}">
                    <TextBlock Style="{ThemeResource BodyLargeTextBlockStyle}" Text="4" />
                </Button>
                <Button
                    Grid.Row="2"
                    Grid.Column="1"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Click="Click_Five"
                    Style="{StaticResource NumberPadButtonStyle}">
                    <TextBlock Style="{ThemeResource BodyLargeTextBlockStyle}" Text="5" />
                </Button>
                <Button
                    Grid.Row="2"
                    Grid.Column="2"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Click="Click_Six"
                    Style="{StaticResource NumberPadButtonStyle}">
                    <TextBlock Style="{ThemeResource BodyLargeTextBlockStyle}" Text="6" />
                </Button>

                <Button
                    Grid.Row="3"
                    Grid.Column="0"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Click="Click_One"
                    Style="{StaticResource NumberPadButtonStyle}">
                    <TextBlock Style="{ThemeResource BodyLargeTextBlockStyle}" Text="1" />
                </Button>
                <Button
                    Grid.Row="3"
                    Grid.Column="1"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Click="Click_Two"
                    Style="{StaticResource NumberPadButtonStyle}">
                    <TextBlock Style="{ThemeResource BodyLargeTextBlockStyle}" Text="2" />
                </Button>
                <Button
                    Grid.Row="3"
                    Grid.Column="2"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Click="Click_Three"
                    Style="{StaticResource NumberPadButtonStyle}">
                    <TextBlock Style="{ThemeResource BodyLargeTextBlockStyle}" Text="3" />
                </Button>

                <Button
                    Grid.Row="4"
                    Grid.Column="0"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Click="Click_DecimalPoint"
                    Style="{StaticResource NumberPadButtonStyle}">
                    <TextBlock Style="{ThemeResource BodyLargeTextBlockStyle}" Text="." />
                </Button>
                <Button
                    Grid.Row="4"
                    Grid.Column="1"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Click="Click_Zero"
                    Style="{StaticResource NumberPadButtonStyle}">
                    <TextBlock Style="{ThemeResource BodyLargeTextBlockStyle}" Text="0" />
                </Button>
                <Button
                    Grid.Row="4"
                    Grid.Column="2"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Click="Click_Calculate"
                    Style="{ThemeResource AccentButtonStyle}">
                    <TextBlock Style="{ThemeResource BodyLargeTextBlockStyle}" Text="=" />
                </Button>
            </Grid>
        </Grid>
    </Border>
</Page>