<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Calculator_WinUI.Views.StandardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Calculator_WinUI.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Border Background="{StaticResource Brush_Layer3}">
        <Grid Margin="5">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="2*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!--<Button Grid.Row="0"
                    Grid.Column="0"
                    Margin="2"
                    Height="40"
                    Width="45"
                    HorizontalAlignment="Left"
                    Click="Click_Menu"
                    Style="{StaticResource Style_ButtonLayer3_5}">
                <Button.Resources>
                    <StaticResource x:Key="ButtonBackgroundPointerOver"
                                    ResourceKey="Brush_Layer4_5" />
                    <StaticResource x:Key="ButtonBorderBrushPointerOver"
                                    ResourceKey="Brush_Layer4_5" />
                    <StaticResource x:Key="ButtonBackgroundPressed"
                                    ResourceKey="Brush_Layer4" />
                    <StaticResource x:Key="ButtonBorderBrushPressed"
                                    ResourceKey="Brush_Layer4" />
                </Button.Resources>
                <StackPanel>
                    <Image Source="ms-appx:///Assets/Icons/menu.png"
                           Height="25"
                           Width="25" />
                </StackPanel>
            </Button>-->

            <TextBlock
                Grid.Row="0"
                Grid.ColumnSpan="4"
                Margin="5,0,0,0"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                Style="{StaticResource Font_TextBlockHeader}"
                Text="Standard" />

            <ScrollViewer
                x:Name="outputScrollviewer"
                Grid.Row="1"
                Grid.ColumnSpan="4"
                Margin="2"
                HorizontalScrollBarVisibility="Visible"
                VerticalScrollBarVisibility="Disabled">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="2*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock
                        x:Name="TextBlock_Calculation"
                        Grid.Row="0"
                        Margin="5,0,5,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Style="{StaticResource Font_TextBlockOutputDisplay}"
                        Text="" />
                    <TextBlock
                        x:Name="TextBlock_InputAndResult"
                        Grid.Row="1"
                        Margin="5,0,5,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        FontSize="50"
                        Style="{StaticResource Font_TextBlockOutputDisplay}"
                        Text="0" />
                </Grid>
            </ScrollViewer>


            <Grid
                Grid.Row="2"
                Grid.RowSpan="2"
                Grid.ColumnSpan="4">
                <Grid.Resources>
                    <StaticResource x:Key="ButtonBackgroundPointerOver" ResourceKey="Brush_Layer6" />
                    <StaticResource x:Key="ButtonBorderBrushPointerOver" ResourceKey="Brush_Layer6" />
                    <StaticResource x:Key="ButtonBackgroundPressed" ResourceKey="Brush_Layer4" />
                    <StaticResource x:Key="ButtonBorderBrushPressed" ResourceKey="Brush_Layer4" />
                </Grid.Resources>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Button
                    Grid.Row="0"
                    Grid.Column="0"
                    Margin="2"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Click="Click_BracketLeft"
                    Style="{StaticResource Style_ButtonLayer5}">
                    <TextBlock Style="{StaticResource Font_ButtonSign}" Text="(" />
                </Button>
                <Button
                    Grid.Row="0"
                    Grid.Column="1"
                    Margin="2"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Click="Click_BracketRight"
                    Style="{StaticResource Style_ButtonLayer5}">
                    <TextBlock Style="{StaticResource Font_ButtonSign}" Text=")" />
                </Button>
                <Button
                    Grid.Row="0"
                    Grid.Column="2"
                    Margin="2"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Click="Click_ClearAllInput"
                    Style="{StaticResource Style_ButtonLayer5}">
                    <TextBlock Style="{StaticResource Font_ButtonSign}" Text="CE" />
                </Button>
                <Button
                    Grid.Row="0"
                    Grid.Column="3"
                    Margin="2"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Click="Click_Backspace"
                    Style="{StaticResource Style_ButtonLayer5}">
                    <Image
                        Width="22"
                        Height="22"
                        Source="ms-appx:///Assets/Icons/backspace.png" />
                </Button>

                <Button
                    Grid.Row="1"
                    Grid.Column="0"
                    Margin="2"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Click="Click_Power1"
                    Style="{StaticResource Style_ButtonLayer5}">
                    <TextBlock Style="{StaticResource Font_ButtonSign}" Text="^2" />
                </Button>
                <Button
                    Grid.Row="1"
                    Grid.Column="1"
                    Margin="2"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Click="CLick_Power2"
                    Style="{StaticResource Style_ButtonLayer5}">
                    <TextBlock Style="{StaticResource Font_ButtonSign}" Text="^" />
                </Button>
                <Button
                    Grid.Row="1"
                    Grid.Column="2"
                    Margin="2"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Click="Click_Root1"
                    Style="{StaticResource Style_ButtonLayer5}">
                    <TextBlock Style="{StaticResource Font_ButtonSign}" Text="2√" />
                </Button>
                <Button
                    Grid.Row="1"
                    Grid.Column="3"
                    Margin="2"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Click="Click_Root2"
                    Style="{StaticResource Style_ButtonLayer5}">
                    <TextBlock Style="{StaticResource Font_ButtonSign}" Text="√" />
                </Button>
            </Grid>


            <Grid
                Grid.Row="4"
                Grid.RowSpan="4"
                Grid.ColumnSpan="3">
                <Grid.Resources>
                    <StaticResource x:Key="ButtonBackgroundPointerOver" ResourceKey="Brush_Layer7" />
                    <StaticResource x:Key="ButtonBorderBrushPointerOver" ResourceKey="Brush_Layer7" />
                    <StaticResource x:Key="ButtonBackgroundPressed" ResourceKey="Brush_Layer5" />
                    <StaticResource x:Key="ButtonBorderBrushPressed" ResourceKey="Brush_Layer5" />
                </Grid.Resources>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Button
                    Grid.Row="0"
                    Grid.Column="0"
                    Margin="2"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Click="Click_Seven"
                    Style="{StaticResource Style_ButtonLayer6}">
                    <TextBlock Style="{StaticResource Font_ButtonSign}" Text="7" />
                </Button>
                <Button
                    Grid.Row="0"
                    Grid.Column="1"
                    Margin="2"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Click="Click_Eight"
                    Style="{StaticResource Style_ButtonLayer6}">
                    <TextBlock Style="{StaticResource Font_ButtonSign}" Text="8" />
                </Button>
                <Button
                    Grid.Row="0"
                    Grid.Column="2"
                    Margin="2"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Click="Click_Nine"
                    Style="{StaticResource Style_ButtonLayer6}">
                    <TextBlock Style="{StaticResource Font_ButtonSign}" Text="9" />
                </Button>

                <Button
                    Grid.Row="1"
                    Grid.Column="0"
                    Margin="2"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Click="Click_Four"
                    Style="{StaticResource Style_ButtonLayer6}">
                    <TextBlock Style="{StaticResource Font_ButtonSign}" Text="4" />
                </Button>
                <Button
                    Grid.Row="1"
                    Grid.Column="1"
                    Margin="2"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Click="Click_Five"
                    Style="{StaticResource Style_ButtonLayer6}">
                    <TextBlock Style="{StaticResource Font_ButtonSign}" Text="5" />
                </Button>
                <Button
                    Grid.Row="1"
                    Grid.Column="2"
                    Margin="2"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Click="Click_Six"
                    Style="{StaticResource Style_ButtonLayer6}">
                    <TextBlock Style="{StaticResource Font_ButtonSign}" Text="6" />
                </Button>

                <Button
                    Grid.Row="2"
                    Grid.Column="0"
                    Margin="2"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Click="Click_One"
                    Style="{StaticResource Style_ButtonLayer6}">
                    <TextBlock Style="{StaticResource Font_ButtonSign}" Text="1" />
                </Button>
                <Button
                    Grid.Row="2"
                    Grid.Column="1"
                    Margin="2"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Click="Click_Two"
                    Style="{StaticResource Style_ButtonLayer6}">
                    <TextBlock Style="{StaticResource Font_ButtonSign}" Text="2" />
                </Button>
                <Button
                    Grid.Row="2"
                    Grid.Column="2"
                    Margin="2"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Click="Click_Three"
                    Style="{StaticResource Style_ButtonLayer6}">
                    <TextBlock Style="{StaticResource Font_ButtonSign}" Text="3" />
                </Button>

                <Button
                    Grid.Row="3"
                    Grid.Column="0"
                    Margin="2"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Click="Click_DecimalPoint"
                    Style="{StaticResource Style_ButtonLayer6}">
                    <TextBlock Style="{StaticResource Font_ButtonSign}" Text="." />
                </Button>
                <Button
                    Grid.Row="3"
                    Grid.Column="1"
                    Margin="2"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Click="Click_Zero"
                    Style="{StaticResource Style_ButtonLayer6}">
                    <TextBlock Style="{StaticResource Font_ButtonSign}" Text="0" />
                </Button>
                <Button
                    Grid.Row="3"
                    Grid.Column="2"
                    Margin="2"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Click="Click_Add"
                    Style="{StaticResource Style_ButtonLayer6}">
                    <TextBlock Style="{StaticResource Font_ButtonSign}" Text="+" />
                </Button>
            </Grid>


            <Grid
                Grid.Row="4"
                Grid.RowSpan="3"
                Grid.Column="3">
                <Grid.Resources>
                    <StaticResource x:Key="ButtonBackgroundPointerOver" ResourceKey="Brush_Layer6" />
                    <StaticResource x:Key="ButtonBorderBrushPointerOver" ResourceKey="Brush_Layer6" />
                    <StaticResource x:Key="ButtonBackgroundPressed" ResourceKey="Brush_Layer4" />
                    <StaticResource x:Key="ButtonBorderBrushPressed" ResourceKey="Brush_Layer4" />
                </Grid.Resources>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Button
                    Grid.Row="0"
                    Margin="2"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Click="Click_Divide"
                    Style="{StaticResource Style_ButtonLayer5}">
                    <TextBlock Style="{StaticResource Font_ButtonSign}" Text="/" />
                </Button>
                <Button
                    Grid.Row="1"
                    Margin="2"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Click="Click_Multiply"
                    Style="{StaticResource Style_ButtonLayer5}">
                    <TextBlock Style="{StaticResource Font_ButtonSign}" Text="*" />
                </Button>
                <Button
                    Grid.Row="2"
                    Margin="2"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Click="Click_Subtract"
                    Style="{StaticResource Style_ButtonLayer5}">
                    <TextBlock Style="{StaticResource Font_ButtonSign}" Text="-" />
                </Button>
            </Grid>

            <Button
                Grid.Row="7"
                Grid.Column="3"
                Margin="2"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Click="Click_Calculate"
                Style="{StaticResource Style_ButtonAccent1}">
                <TextBlock Style="{StaticResource Font_ButtonSign}" Text="=" />
            </Button>

        </Grid>
    </Border>
</Page>