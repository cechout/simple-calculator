<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Calculator_WinUI.Views.StandardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Calculator_WinUI.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Border Background="{ThemeResource SolidBackgroundFillColorBaseBrush}">
        <Grid
            Margin="4,4,4,4"
            ColumnSpacing="2.5"
            RowSpacing="2.5">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="2*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!--  header  -->
            <Grid
                Grid.Row="0"
                Grid.ColumnSpan="4"
                Height="38"
                Margin="45,0,0,0"
                Background="Transparent">
                <StackPanel
                    HorizontalAlignment="Left"
                    Orientation="Horizontal"
                    Spacing="8">

                    <TextBlock
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Style="{ThemeResource SubtitleTextBlockStyle}"
                        Text="Standard" />

                    <Button
                        Width="32"
                        Height="32"
                        Padding="0"
                        Style="{ThemeResource SubtleButtonStyle}">
                        <FontIcon FontSize="16" Glyph="&#xE81C;" />
                    </Button>
                </StackPanel>

                <Button
                    Width="32"
                    Height="32"
                    Padding="0"
                    HorizontalAlignment="Right"
                    Style="{ThemeResource SubtleButtonStyle}">
                    <FontIcon FontSize="16" Glyph="&#xE8A7;" />
                </Button>
            </Grid>

            <!--  output display  -->
            <ScrollViewer
                x:Name="outputScrollviewer"
                Grid.Row="1"
                Grid.ColumnSpan="4"
                Background="Transparent"
                HorizontalScrollBarVisibility="Auto"
                VerticalScrollBarVisibility="Disabled">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="2*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock
                        Grid.Row="0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Style="{ThemeResource BodyLargeTextBlockStyle}"
                        Text="{x:Bind ViewModel.CalculationText, Mode=OneWay}" />

                    <TextBlock
                        Grid.Row="1"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Style="{ThemeResource TitleLargeTextBlockStyle}"
                        Text="{x:Bind ViewModel.InputAndResultText, Mode=OneWay}" />
                </Grid>
            </ScrollViewer>

            <!--  input buttons  -->
            <Button
                Grid.Row="2"
                Grid.Column="0"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Command="{x:Bind ViewModel.InputCommand}"
                CommandParameter="("
                Style="{StaticResource OperatorButtonStyle}">
                <TextBlock Style="{ThemeResource BodyLargeTextBlockStyle}" Text="(" />
            </Button>
            <Button
                Grid.Row="2"
                Grid.Column="1"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Command="{x:Bind ViewModel.InputCommand}"
                CommandParameter=")"
                Style="{StaticResource OperatorButtonStyle}">
                <TextBlock Style="{ThemeResource BodyLargeTextBlockStyle}" Text=")" />
            </Button>
            <Button
                Grid.Row="2"
                Grid.Column="2"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Command="{x:Bind ViewModel.ClearCommand}"
                Style="{StaticResource OperatorButtonStyle}">
                <TextBlock Style="{ThemeResource BodyLargeTextBlockStyle}" Text="CE" />
            </Button>
            <Button
                Grid.Row="2"
                Grid.Column="3"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Command="{x:Bind ViewModel.BackspaceCommand}"
                Style="{StaticResource OperatorButtonStyle}">
                <FontIcon FontSize="16" Glyph="&#xE8A7;" />
            </Button>

            <Button
                Grid.Row="3"
                Grid.Column="0"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Command="{x:Bind ViewModel.InputCommand}"
                CommandParameter="^2"
                Style="{StaticResource OperatorButtonStyle}">
                <TextBlock Style="{ThemeResource BodyLargeTextBlockStyle}" Text="^2" />
            </Button>
            <Button
                Grid.Row="3"
                Grid.Column="1"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Command="{x:Bind ViewModel.InputCommand}"
                CommandParameter="^"
                Style="{StaticResource OperatorButtonStyle}">
                <TextBlock Style="{ThemeResource BodyLargeTextBlockStyle}" Text="^" />
            </Button>
            <Button
                Grid.Row="3"
                Grid.Column="2"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Command="{x:Bind ViewModel.InputCommand}"
                CommandParameter="2√"
                Style="{StaticResource OperatorButtonStyle}">
                <TextBlock Style="{ThemeResource BodyLargeTextBlockStyle}" Text="2√" />
            </Button>
            <Button
                Grid.Row="3"
                Grid.Column="3"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Command="{x:Bind ViewModel.InputCommand}"
                CommandParameter="√"
                Style="{StaticResource OperatorButtonStyle}">
                <TextBlock Style="{ThemeResource BodyLargeTextBlockStyle}" Text="√" />
            </Button>

            <Button
                Grid.Row="4"
                Grid.Column="0"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Command="{x:Bind ViewModel.InputCommand}"
                CommandParameter="7"
                Style="{StaticResource NumberPadButtonStyle}">
                <TextBlock Style="{ThemeResource BodyLargeTextBlockStyle}" Text="7" />
            </Button>
            <Button
                Grid.Row="4"
                Grid.Column="1"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Command="{x:Bind ViewModel.InputCommand}"
                CommandParameter="8"
                Style="{StaticResource NumberPadButtonStyle}">
                <TextBlock Style="{ThemeResource BodyLargeTextBlockStyle}" Text="8" />
            </Button>
            <Button
                Grid.Row="4"
                Grid.Column="2"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Command="{x:Bind ViewModel.InputCommand}"
                CommandParameter="9"
                Style="{StaticResource NumberPadButtonStyle}">
                <TextBlock Style="{ThemeResource BodyLargeTextBlockStyle}" Text="9" />
            </Button>
            <Button
                Grid.Row="4"
                Grid.Column="3"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Command="{x:Bind ViewModel.InputCommand}"
                CommandParameter="/"
                Style="{StaticResource OperatorButtonStyle}">
                <TextBlock Style="{ThemeResource BodyLargeTextBlockStyle}" Text="/" />
            </Button>

            <Button
                Grid.Row="5"
                Grid.Column="0"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Command="{x:Bind ViewModel.InputCommand}"
                CommandParameter="4"
                Style="{StaticResource NumberPadButtonStyle}">
                <TextBlock Style="{ThemeResource BodyLargeTextBlockStyle}" Text="4" />
            </Button>
            <Button
                Grid.Row="5"
                Grid.Column="1"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Command="{x:Bind ViewModel.InputCommand}"
                CommandParameter="5"
                Style="{StaticResource NumberPadButtonStyle}">
                <TextBlock Style="{ThemeResource BodyLargeTextBlockStyle}" Text="5" />
            </Button>
            <Button
                Grid.Row="5"
                Grid.Column="2"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Command="{x:Bind ViewModel.InputCommand}"
                CommandParameter="6"
                Style="{StaticResource NumberPadButtonStyle}">
                <TextBlock Style="{ThemeResource BodyLargeTextBlockStyle}" Text="6" />
            </Button>
            <Button
                Grid.Row="5"
                Grid.Column="3"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Command="{x:Bind ViewModel.InputCommand}"
                CommandParameter="*"
                Style="{StaticResource OperatorButtonStyle}">
                <TextBlock Style="{ThemeResource BodyLargeTextBlockStyle}" Text="*" />
            </Button>

            <Button
                Grid.Row="6"
                Grid.Column="0"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Command="{x:Bind ViewModel.InputCommand}"
                CommandParameter="1"
                Style="{StaticResource NumberPadButtonStyle}">
                <TextBlock Style="{ThemeResource BodyLargeTextBlockStyle}" Text="1" />
            </Button>
            <Button
                Grid.Row="6"
                Grid.Column="1"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Command="{x:Bind ViewModel.InputCommand}"
                CommandParameter="2"
                Style="{StaticResource NumberPadButtonStyle}">
                <TextBlock Style="{ThemeResource BodyLargeTextBlockStyle}" Text="2" />
            </Button>
            <Button
                Grid.Row="6"
                Grid.Column="2"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Command="{x:Bind ViewModel.InputCommand}"
                CommandParameter="3"
                Style="{StaticResource NumberPadButtonStyle}">
                <TextBlock Style="{ThemeResource BodyLargeTextBlockStyle}" Text="3" />
            </Button>
            <Button
                Grid.Row="6"
                Grid.Column="3"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Command="{x:Bind ViewModel.InputCommand}"
                CommandParameter="-"
                Style="{StaticResource OperatorButtonStyle}">
                <TextBlock Style="{ThemeResource BodyLargeTextBlockStyle}" Text="-" />
            </Button>

            <Button
                Grid.Row="7"
                Grid.Column="0"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Command="{x:Bind ViewModel.InputCommand}"
                CommandParameter="."
                Style="{StaticResource NumberPadButtonStyle}">
                <TextBlock Style="{ThemeResource BodyLargeTextBlockStyle}" Text="." />
            </Button>
            <Button
                Grid.Row="7"
                Grid.Column="1"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Command="{x:Bind ViewModel.InputCommand}"
                CommandParameter="0"
                Style="{StaticResource NumberPadButtonStyle}">
                <TextBlock Style="{ThemeResource BodyLargeTextBlockStyle}" Text="0" />
            </Button>
            <Button
                Grid.Row="7"
                Grid.Column="2"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Command="{x:Bind ViewModel.InputCommand}"
                CommandParameter="+"
                Style="{StaticResource NumberPadButtonStyle}">
                <TextBlock Style="{ThemeResource BodyLargeTextBlockStyle}" Text="+" />
            </Button>
            <!--<Border
                Grid.Row="7"
                Grid.Column="3"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Background="{ThemeResource OperatorBackground}" />-->
            <Button
                Grid.Row="7"
                Grid.Column="3"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Command="{x:Bind ViewModel.CalculateCommand}"
                Style="{ThemeResource AccentButtonStyle}">
                <TextBlock Style="{ThemeResource BodyLargeTextBlockStyle}" Text="=" />
            </Button>
        </Grid>
    </Border>
</Page>