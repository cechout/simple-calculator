<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Calculator_WinUI.Views.StandardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Calculator_WinUI.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Border Background="{ThemeResource SolidBackgroundFillColorBaseBrush}">
        <Grid Margin="4,4,4,4">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="2*" />
                <RowDefinition Height="6*" />
            </Grid.RowDefinitions>


            <!--  header  -->
            <Grid
                Grid.Row="0"
                Height="38"
                Margin="45,0,0,0"
                Background="Transparent">
                <StackPanel
                    HorizontalAlignment="Left"
                    Orientation="Horizontal"
                    Spacing="8">

                    <!--  page title  -->
                    <TextBlock
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Style="{ThemeResource SubtitleTextBlockStyle}"
                        Text="Standard" />

                    <!--  compact mode button  -->
                    <!--<Button
                        Width="32"
                        Height="32"
                        Padding="0"
                        Style="{ThemeResource SubtleButtonStyle}">
                        <FontIcon FontSize="16" Glyph="&#xE81C;" />
                    </Button>-->
                </StackPanel>

                <!--<Button
                    Width="32"
                    Height="32"
                    Padding="0"
                    HorizontalAlignment="Right"
                    Style="{ThemeResource SubtleButtonStyle}">
                    <FontIcon FontSize="16" Glyph="&#xE8A7;" />
                </Button>-->
            </Grid>


            <!--  output display (old)  -->
            <!--<ScrollViewer
                x:Name="outputScrollviewer"
                Grid.Row="1"
                Grid.ColumnSpan="4"
                Margin="4,0,4,8"
                Background="Transparent"
                HorizontalScrollBarVisibility="Auto"
                VerticalScrollBarVisibility="Disabled">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="2*" />
                        <RowDefinition Height="3*" MinHeight="40" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock
                        Grid.Row="0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Style="{ThemeResource BodyTextBlockStyle}"
                        Text="{x:Bind ViewModel.CalculationText, Mode=OneWay}" />

                    <TextBlock
                        Grid.Row="1"
                        Margin="0,-8,0,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Style="{ThemeResource TitleLargeTextBlockStyle}"
                        Text="{x:Bind ViewModel.InputAndResultText, Mode=OneWay}" />
                </Grid>
            </ScrollViewer>-->


            <!--  calculator display  -->
            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="2*" />
                    <RowDefinition Height="3*" MinHeight="40" />
                </Grid.RowDefinitions>

                <WebView2
                    x:Name="MathWebView1"
                    Grid.Row="0"
                    Margin="4,0,4,0"
                    DefaultBackgroundColor="Transparent" />

                <WebView2
                    x:Name="MathWebView2"
                    Grid.Row="1"
                    Margin="4,0,4,8"
                    DefaultBackgroundColor="Transparent" />
            </Grid>


            <!--  input buttons  -->
            <Grid
                Grid.Row="2"
                ColumnSpacing="2.5"
                RowSpacing="2.5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!--  extra buttons  -->
                <Button
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Command="{x:Bind ViewModel.InputCommand}"
                    CommandParameter="cmd_pi"
                    Style="{StaticResource OperatorButtonStyle}"
                    Visibility="Collapsed">
                    <TextBlock Style="{ThemeResource BodyTextBlockStyle}" Text="π" />
                </Button>
                <Button
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Command="{x:Bind ViewModel.InputCommand}"
                    CommandParameter="cmd_frac"
                    Style="{StaticResource OperatorButtonStyle}"
                    Visibility="Collapsed">
                    <TextBlock Style="{ThemeResource BodyTextBlockStyle}" Text="x!" />
                </Button>

                <!--  row 0  -->
                <Button
                    Grid.Row="0"
                    Grid.Column="0"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Command="{x:Bind ViewModel.InputCommand}"
                    CommandParameter="cmd_shift"
                    Style="{StaticResource OperatorButtonStyle}"
                    Visibility="{x:Bind ViewModel.NormalVisibility, Mode=OneWay}">
                    <FontIcon FontSize="14" Glyph="&#xE752;" />
                </Button>
                <Button
                    Grid.Row="0"
                    Grid.Column="0"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Command="{x:Bind ViewModel.InputCommand}"
                    CommandParameter="cmd_shift"
                    Style="{ThemeResource AccentButtonStyle}"
                    Visibility="{x:Bind ViewModel.ShiftVisibility, Mode=OneWay}">
                    <FontIcon FontSize="14" Glyph="&#xE752;" />
                </Button>
                <Button
                    Grid.Row="0"
                    Grid.Column="1"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Command="{x:Bind ViewModel.InputCommand}"
                    CommandParameter="cmd_nav_left"
                    Style="{StaticResource OperatorButtonStyle}">
                    <FontIcon FontSize="14" Glyph="&#xE76B;" />
                </Button>
                <Grid
                    Grid.Row="0"
                    Grid.Column="2"
                    VerticalAlignment="Stretch"
                    RowSpacing="2.5">
                    <Grid.RowDefinitions>
                        <RowDefinition />
                        <RowDefinition />
                    </Grid.RowDefinitions>
                    <Button
                        Grid.Row="0"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        Command="{x:Bind ViewModel.InputCommand}"
                        CommandParameter="cmd_nav_up"
                        CornerRadius="0,0,0,0"
                        Style="{StaticResource OperatorButtonStyle}">
                        <FontIcon FontSize="14" Glyph="&#xE70E;" />
                    </Button>
                    <Button
                        Grid.Row="1"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        Command="{x:Bind ViewModel.InputCommand}"
                        CommandParameter="cmd_nav_down"
                        Style="{StaticResource OperatorButtonStyle}">
                        <FontIcon FontSize="14" Glyph="&#xE70D;" />
                    </Button>
                </Grid>
                <Button
                    Grid.Row="0"
                    Grid.Column="3"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Command="{x:Bind ViewModel.InputCommand}"
                    CommandParameter="cmd_nav_right"
                    Style="{StaticResource OperatorButtonStyle}">
                    <FontIcon FontSize="14" Glyph="&#xE76C;" />
                </Button>
                <Button
                    Grid.Row="0"
                    Grid.Column="4"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Command="{x:Bind ViewModel.InputCommand}"
                    CommandParameter="cmd_more"
                    Style="{StaticResource OperatorButtonStyle}">
                    <FontIcon FontSize="14" Glyph="&#xE712;" />
                </Button>

                <!--  row 1  -->
                <Button
                    Grid.Row="1"
                    Grid.Column="0"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Command="{x:Bind ViewModel.InputCommand}"
                    CommandParameter="cmd_frac"
                    Style="{StaticResource OperatorButtonStyle}">
                    <TextBlock Style="{ThemeResource BodyTextBlockStyle}" Text="x/y" />
                </Button>
                <Button
                    Grid.Row="1"
                    Grid.Column="1"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Command="{x:Bind ViewModel.InputCommand}"
                    CommandParameter="cmd_sqrt"
                    Style="{StaticResource OperatorButtonStyle}"
                    Visibility="{x:Bind ViewModel.NormalVisibility, Mode=OneWay}">
                    <TextBlock Style="{ThemeResource BodyTextBlockStyle}" Text="²√" />
                </Button>
                <Button
                    Grid.Row="1"
                    Grid.Column="1"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Command="{x:Bind ViewModel.InputCommand}"
                    CommandParameter="cmd_root_n"
                    Style="{StaticResource OperatorButtonStyle}"
                    Visibility="{x:Bind ViewModel.ShiftVisibility, Mode=OneWay}">
                    <TextBlock Style="{ThemeResource BodyTextBlockStyle}" Text="ⁿ√" />
                </Button>
                <Button
                    Grid.Row="1"
                    Grid.Column="2"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Command="{x:Bind ViewModel.InputCommand}"
                    CommandParameter="cmd_pow_2"
                    Style="{StaticResource OperatorButtonStyle}"
                    Visibility="{x:Bind ViewModel.NormalVisibility, Mode=OneWay}">
                    <TextBlock Style="{ThemeResource BodyTextBlockStyle}" Text="x²" />
                </Button>
                <Button
                    Grid.Row="1"
                    Grid.Column="2"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Command="{x:Bind ViewModel.InputCommand}"
                    CommandParameter="cmd_pow_n"
                    Style="{StaticResource OperatorButtonStyle}"
                    Visibility="{x:Bind ViewModel.ShiftVisibility, Mode=OneWay}">
                    <TextBlock Style="{ThemeResource BodyTextBlockStyle}" Text="xⁿ" />
                </Button>
                <Button
                    Grid.Row="1"
                    Grid.Column="3"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Command="{x:Bind ViewModel.InputCommand}"
                    CommandParameter="cmd_ln"
                    Style="{StaticResource OperatorButtonStyle}"
                    Visibility="{x:Bind ViewModel.NormalVisibility, Mode=OneWay}">
                    <TextBlock Style="{ThemeResource BodyTextBlockStyle}" Text="ln" />
                </Button>
                <Button
                    Grid.Row="1"
                    Grid.Column="3"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Command="{x:Bind ViewModel.InputCommand}"
                    CommandParameter="cmd_log"
                    Style="{StaticResource OperatorButtonStyle}"
                    Visibility="{x:Bind ViewModel.ShiftVisibility, Mode=OneWay}">
                    <TextBlock Style="{ThemeResource BodyTextBlockStyle}" Text="log" />
                </Button>
                <Button
                    Grid.Row="1"
                    Grid.Column="4"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Command="{x:Bind ViewModel.InputCommand}"
                    CommandParameter="cmd_e"
                    Style="{StaticResource OperatorButtonStyle}">
                    <TextBlock Style="{ThemeResource BodyTextBlockStyle}" Text="e" />
                </Button>

                <!--  row 2  -->
                <Button
                    Grid.Row="2"
                    Grid.Column="0"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Command="{x:Bind ViewModel.InputCommand}"
                    CommandParameter="cmd_sin"
                    Style="{StaticResource OperatorButtonStyle}"
                    Visibility="{x:Bind ViewModel.NormalVisibility, Mode=OneWay}">
                    <TextBlock Style="{ThemeResource BodyTextBlockStyle}" Text="sin" />
                </Button>
                <Button
                    Grid.Row="2"
                    Grid.Column="0"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Command="{x:Bind ViewModel.InputCommand}"
                    CommandParameter="cmd_asin"
                    Style="{StaticResource OperatorButtonStyle}"
                    Visibility="{x:Bind ViewModel.ShiftVisibility, Mode=OneWay}">
                    <TextBlock Style="{ThemeResource BodyTextBlockStyle}" Text="sin⁻¹" />
                </Button>
                <Button
                    Grid.Row="2"
                    Grid.Column="1"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Command="{x:Bind ViewModel.InputCommand}"
                    CommandParameter="cmd_cos"
                    Style="{StaticResource OperatorButtonStyle}"
                    Visibility="{x:Bind ViewModel.NormalVisibility, Mode=OneWay}">
                    <TextBlock Style="{ThemeResource BodyTextBlockStyle}" Text="cos" />
                </Button>
                <Button
                    Grid.Row="2"
                    Grid.Column="1"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Command="{x:Bind ViewModel.InputCommand}"
                    CommandParameter="cmd_acos"
                    Style="{StaticResource OperatorButtonStyle}"
                    Visibility="{x:Bind ViewModel.ShiftVisibility, Mode=OneWay}">
                    <TextBlock Style="{ThemeResource BodyTextBlockStyle}" Text="cos⁻¹" />
                </Button>
                <Button
                    Grid.Row="2"
                    Grid.Column="2"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Command="{x:Bind ViewModel.InputCommand}"
                    CommandParameter="cmd_tan"
                    Style="{StaticResource OperatorButtonStyle}"
                    Visibility="{x:Bind ViewModel.NormalVisibility, Mode=OneWay}">
                    <TextBlock Style="{ThemeResource BodyTextBlockStyle}" Text="tan" />
                </Button>
                <Button
                    Grid.Row="2"
                    Grid.Column="2"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Command="{x:Bind ViewModel.InputCommand}"
                    CommandParameter="cmd_atan"
                    Style="{StaticResource OperatorButtonStyle}"
                    Visibility="{x:Bind ViewModel.ShiftVisibility, Mode=OneWay}">
                    <TextBlock Style="{ThemeResource BodyTextBlockStyle}" Text="tan⁻¹" />
                </Button>
                <Button
                    Grid.Row="2"
                    Grid.Column="3"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Command="{x:Bind ViewModel.InputCommand}"
                    CommandParameter="cmd_paren_open"
                    Style="{StaticResource OperatorButtonStyle}">
                    <TextBlock Style="{ThemeResource BodyTextBlockStyle}" Text="(" />
                </Button>
                <Button
                    Grid.Row="2"
                    Grid.Column="4"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Command="{x:Bind ViewModel.InputCommand}"
                    CommandParameter="cmd_paren_close"
                    Style="{StaticResource OperatorButtonStyle}">
                    <TextBlock Style="{ThemeResource BodyTextBlockStyle}" Text=")" />
                </Button>

                <!--  row 3  -->
                <Button
                    Grid.Row="3"
                    Grid.Column="0"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Command="{x:Bind ViewModel.InputCommand}"
                    CommandParameter="7"
                    Style="{StaticResource NumberPadButtonStyle}">
                    <TextBlock Style="{ThemeResource BodyLargeTextBlockStyle}" Text="7" />
                </Button>
                <Button
                    Grid.Row="3"
                    Grid.Column="1"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Command="{x:Bind ViewModel.InputCommand}"
                    CommandParameter="8"
                    Style="{StaticResource NumberPadButtonStyle}">
                    <TextBlock Style="{ThemeResource BodyLargeTextBlockStyle}" Text="8" />
                </Button>
                <Button
                    Grid.Row="3"
                    Grid.Column="2"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Command="{x:Bind ViewModel.InputCommand}"
                    CommandParameter="9"
                    Style="{StaticResource NumberPadButtonStyle}">
                    <TextBlock Style="{ThemeResource BodyLargeTextBlockStyle}" Text="9" />
                </Button>
                <Button
                    Grid.Row="3"
                    Grid.Column="3"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Command="{x:Bind ViewModel.BackspaceCommand}"
                    Style="{StaticResource OperatorButtonStyle}">
                    <FontIcon FontSize="16" Glyph="&#xE750;" />
                </Button>
                <Button
                    Grid.Row="3"
                    Grid.Column="4"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Command="{x:Bind ViewModel.ClearCommand}"
                    Style="{StaticResource OperatorButtonStyle}">
                    <TextBlock Style="{ThemeResource BodyTextBlockStyle}" Text="AC" />
                </Button>

                <!--  row 4  -->
                <Button
                    Grid.Row="4"
                    Grid.Column="0"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Command="{x:Bind ViewModel.InputCommand}"
                    CommandParameter="4"
                    Style="{StaticResource NumberPadButtonStyle}">
                    <TextBlock Style="{ThemeResource BodyLargeTextBlockStyle}" Text="4" />
                </Button>
                <Button
                    Grid.Row="4"
                    Grid.Column="1"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Command="{x:Bind ViewModel.InputCommand}"
                    CommandParameter="5"
                    Style="{StaticResource NumberPadButtonStyle}">
                    <TextBlock Style="{ThemeResource BodyLargeTextBlockStyle}" Text="5" />
                </Button>
                <Button
                    Grid.Row="4"
                    Grid.Column="2"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Command="{x:Bind ViewModel.InputCommand}"
                    CommandParameter="6"
                    Style="{StaticResource NumberPadButtonStyle}">
                    <TextBlock Style="{ThemeResource BodyLargeTextBlockStyle}" Text="6" />
                </Button>
                <Button
                    Grid.Row="4"
                    Grid.Column="3"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Command="{x:Bind ViewModel.InputCommand}"
                    CommandParameter="*"
                    Style="{StaticResource OperatorButtonStyle}">
                    <FontIcon FontSize="14" Glyph="&#xE947;" />
                </Button>
                <Button
                    Grid.Row="4"
                    Grid.Column="4"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Command="{x:Bind ViewModel.InputCommand}"
                    CommandParameter="/"
                    Style="{StaticResource OperatorButtonStyle}">
                    <FontIcon FontSize="14" Glyph="&#xE94A;" />
                </Button>

                <!--  row 5  -->
                <Button
                    Grid.Row="5"
                    Grid.Column="0"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Command="{x:Bind ViewModel.InputCommand}"
                    CommandParameter="1"
                    Style="{StaticResource NumberPadButtonStyle}">
                    <TextBlock Style="{ThemeResource BodyLargeTextBlockStyle}" Text="1" />
                </Button>
                <Button
                    Grid.Row="5"
                    Grid.Column="1"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Command="{x:Bind ViewModel.InputCommand}"
                    CommandParameter="2"
                    Style="{StaticResource NumberPadButtonStyle}">
                    <TextBlock Style="{ThemeResource BodyLargeTextBlockStyle}" Text="2" />
                </Button>
                <Button
                    Grid.Row="5"
                    Grid.Column="2"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Command="{x:Bind ViewModel.InputCommand}"
                    CommandParameter="3"
                    Style="{StaticResource NumberPadButtonStyle}">
                    <TextBlock Style="{ThemeResource BodyLargeTextBlockStyle}" Text="3" />
                </Button>
                <Button
                    Grid.Row="5"
                    Grid.Column="3"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Command="{x:Bind ViewModel.InputCommand}"
                    CommandParameter="+"
                    Style="{StaticResource OperatorButtonStyle}">
                    <FontIcon FontSize="14" Glyph="&#xE948;" />
                </Button>
                <Button
                    Grid.Row="5"
                    Grid.Column="4"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Command="{x:Bind ViewModel.InputCommand}"
                    CommandParameter="-"
                    Style="{StaticResource OperatorButtonStyle}">
                    <FontIcon FontSize="14" Glyph="&#xE949;" />
                </Button>

                <!--  row 6  -->
                <Button
                    Grid.Row="6"
                    Grid.Column="1"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Command="{x:Bind ViewModel.InputCommand}"
                    CommandParameter="."
                    Style="{StaticResource NumberPadButtonStyle}">
                    <TextBlock Style="{ThemeResource BodyLargeTextBlockStyle}" Text="." />
                </Button>
                <Button
                    Grid.Row="6"
                    Grid.Column="0"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Command="{x:Bind ViewModel.InputCommand}"
                    CommandParameter="0"
                    Style="{StaticResource NumberPadButtonStyle}">
                    <TextBlock Style="{ThemeResource BodyLargeTextBlockStyle}" Text="0" />
                </Button>
                <Button
                    Grid.Row="6"
                    Grid.Column="2"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Command="{x:Bind ViewModel.InputCommand}"
                    CommandParameter="0"
                    Style="{StaticResource NumberPadButtonStyle}">
                    <TextBlock Style="{ThemeResource BodyLargeTextBlockStyle}" Text="*10ⁿ" />
                </Button>
                <Button
                    Grid.Row="6"
                    Grid.Column="3"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Command="{x:Bind ViewModel.InputCommand}"
                    CommandParameter="+"
                    Style="{StaticResource OperatorButtonStyle}">
                    <FontIcon FontSize="14" Glyph="&#xE8AB;" />
                </Button>
                <Button
                    Grid.Row="6"
                    Grid.Column="4"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Command="{x:Bind ViewModel.CalculateCommand}"
                    Style="{ThemeResource AccentButtonStyle}">
                    <FontIcon
                        FontSize="14"
                        FontWeight="Bold"
                        Glyph="&#xE94E;" />
                </Button>
            </Grid>

        </Grid>
    </Border>
</Page>