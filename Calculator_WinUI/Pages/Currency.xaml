<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="Calculator_WinUI.Pages.Currency"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:Calculator_WinUI.Pages"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d">

    <Border Background="{StaticResource Brush_Layer3}">
        <Grid Margin="5">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="5*" />
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Button Grid.Row="0"
                    Grid.Column="0"
                    Margin="2"
                    Height="40"
                    Width="45"
                    HorizontalAlignment="Left"
                    Click="MenuClick"
                    Style="{StaticResource Style_ButtonLayer3_5}">
                <Button.Resources>
                    <StaticResource x:Key="ButtonBackgroundPointerOver"
                                    ResourceKey="Brush_Layer4_5" />
                    <StaticResource x:Key="ButtonBorderBrushPointerOver"
                                    ResourceKey="Brush_Layer4_5" />
                    <StaticResource x:Key="ButtonBackgroundPressed"
                                    ResourceKey="Brush_Layer4" />
                    <StaticResource x:Key="ButtonBorderBrushPressed"
                                    ResourceKey="Brush_Layer4" />
                </Button.Resources>
                <StackPanel>
                    <Image Source="ms-appx:///Assets/Icons/menu.png"
                           Height="25"
                           Width="25" />
                </StackPanel>
            </Button>

            <TextBlock Grid.Row="0"
                       Grid.Column="0"
                       Grid.ColumnSpan="3"
                       Margin="55,5,5,5"
                       Text="Menu"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Center"
                       Style="{StaticResource Font_TextBlockHeader}" />


            <Button Grid.Row="1"
                    Grid.Column="0"
                    Grid.ColumnSpan="3"
                    Margin="2"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Right"
                    Style="{StaticResource Style_ButtonLayer3_5}"
                    Click="Click_SelectionCurrency1">
                <Button.Resources>
                    <StaticResource x:Key="ButtonBackgroundPointerOver"
                                    ResourceKey="Brush_Layer4_5" />
                    <StaticResource x:Key="ButtonBackgroundPressed"
                                    ResourceKey="Brush_Layer4" />
                </Button.Resources>
                <TextBlock Margin="0,0,7,0"
                           Text="Europe-Euro"
                           Foreground="Gray"
                           Style="{StaticResource Font_SelectionButton}"
                           x:Name="TextBlock_SelectedCurrency1" />
            </Button>

            <ScrollViewer Grid.Row="2"
                          Grid.Column="0"
                          Grid.ColumnSpan="3"
                          Margin="2"
                          VerticalScrollBarVisibility="Disabled"
                          HorizontalScrollBarVisibility="Visible">
                <TextBlock Margin="5,-3,5,0"
                           x:Name="TextBlock_Currency1"
                           Text="0"
                           Foreground="White"
                           FontSize="38"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Bottom"
                           Style="{StaticResource Font_TextBlockOutputDisplay}" />
            </ScrollViewer>

            <Button Grid.Row="3"
                    Grid.Column="0"
                    Grid.ColumnSpan="3"
                    Margin="2"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Right"
                    Style="{StaticResource Style_ButtonLayer3_5}"
                    Click="Click_SelectionCurrency2">
                <Button.Resources>
                    <StaticResource x:Key="ButtonBackgroundPointerOver"
                                    ResourceKey="Brush_Layer4_5" />
                    <StaticResource x:Key="ButtonBackgroundPressed"
                                    ResourceKey="Brush_Layer4" />
                </Button.Resources>
                <TextBlock Margin="0,0,7,0"
                           Text="United States-Dollar"
                           Foreground="Gray"
                           Style="{StaticResource Font_SelectionButton}"
                           x:Name="TextBlock_SelectedCurrency2" />
            </Button>

            <ScrollViewer Grid.Row="4"
                          Grid.Column="0"
                          Grid.ColumnSpan="3"
                          Margin="2"
                          VerticalScrollBarVisibility="Disabled"
                          HorizontalScrollBarVisibility="Visible">
                <TextBlock Margin="5,-3,5,0"
                           x:Name="TextBlock_Currency2"
                           Text="0"
                           FontWeight="SemiBold"
                           Foreground="White"
                           FontSize="38"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Bottom" />
            </ScrollViewer>

            <Border Grid.Row="5"
                    Grid.Column="0"
                    Grid.ColumnSpan="3"
                    Margin="2"
                    Background="{StaticResource Brush_Layer3}">
                <TextBlock Margin="0,0,7,0"
                           Text="1 EUR = 1.08 USD"
                           Foreground="{StaticResource Brush_Accent1}"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"
                           Style="{StaticResource Font_SelectionButton}"
                           x:Name="TextBlock_CurrencyRate" />
            </Border>


            <Grid Grid.Row="6"
                  Grid.Column="0"
                  Grid.ColumnSpan="3">
                <Grid.Resources>
                    <StaticResource x:Key="ButtonBackgroundPointerOver"
                                    ResourceKey="Brush_Layer7" />
                    <StaticResource x:Key="ButtonBorderBrushPointerOver"
                                    ResourceKey="Brush_Layer7" />
                    <StaticResource x:Key="ButtonBackgroundPressed"
                                    ResourceKey="Brush_Layer5" />
                    <StaticResource x:Key="ButtonBorderBrushPressed"
                                    ResourceKey="Brush_Layer5" />
                </Grid.Resources>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Button Grid.Row="0"
                        Grid.Column="0"
                        Margin="2"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        Style="{StaticResource Style_ButtonLayer5}"
                        Click="Click_Refresh">
                    <Button.Resources>
                        <StaticResource x:Key="ButtonBackgroundPointerOver"
                                        ResourceKey="Brush_Layer6" />
                        <StaticResource x:Key="ButtonBackgroundPressed"
                                        ResourceKey="Brush_Layer4" />
                    </Button.Resources>
                    <Image Height="22"
                           Width="22"
                           Source="ms-appx:///Assets/Icons/synchrosize.png" />
                </Button>
                <Button Grid.Row="0"
                        Grid.Column="1"
                        Margin="2"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        Style="{StaticResource Style_ButtonLayer5}"
                        Click="Click_ClearAllInput">
                    <Button.Resources>
                        <StaticResource x:Key="ButtonBackgroundPointerOver"
                                        ResourceKey="Brush_Layer6" />
                        <StaticResource x:Key="ButtonBackgroundPressed"
                                        ResourceKey="Brush_Layer4" />
                    </Button.Resources>
                    <TextBlock Text="CE"
                               Style="{StaticResource Font_ButtonSign}" />
                </Button>
                <Button Grid.Row="0"
                        Grid.Column="2"
                        Margin="2"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        Style="{StaticResource Style_ButtonLayer5}"
                        Click="Click_Backspace">
                    <Button.Resources>
                        <StaticResource x:Key="ButtonBackgroundPointerOver"
                                        ResourceKey="Brush_Layer6" />
                        <StaticResource x:Key="ButtonBackgroundPressed"
                                        ResourceKey="Brush_Layer4" />
                    </Button.Resources>
                    <Image Height="22"
                           Width="22"
                           Source="ms-appx:///Assets/Icons/backspace.png" />
                </Button>

                <Button Grid.Row="1"
                        Grid.Column="0"
                        Margin="2"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        Style="{StaticResource Style_ButtonLayer6}"
                        Click="Click_Seven">
                    <TextBlock Text="7"
                               Style="{StaticResource Font_ButtonSign}" />
                </Button>
                <Button Grid.Row="1"
                        Grid.Column="1"
                        Margin="2"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        Style="{StaticResource Style_ButtonLayer6}"
                        Click="Click_Eight">
                    <TextBlock Text="8"
                               Style="{StaticResource Font_ButtonSign}" />
                </Button>
                <Button Grid.Row="1"
                        Grid.Column="2"
                        Margin="2"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        Style="{StaticResource Style_ButtonLayer6}"
                        Click="Click_Nine">
                    <TextBlock Text="9"
                               Style="{StaticResource Font_ButtonSign}" />
                </Button>

                <Button Grid.Row="2"
                        Grid.Column="0"
                        Margin="2"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        Style="{StaticResource Style_ButtonLayer6}"
                        Click="Click_Four">
                    <TextBlock Text="4"
                               Style="{StaticResource Font_ButtonSign}" />
                </Button>
                <Button Grid.Row="2"
                        Grid.Column="1"
                        Margin="2"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        Style="{StaticResource Style_ButtonLayer6}"
                        Click="Click_Five">
                    <TextBlock Text="5"
                               Style="{StaticResource Font_ButtonSign}" />
                </Button>
                <Button Grid.Row="2"
                        Grid.Column="2"
                        Margin="2"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        Style="{StaticResource Style_ButtonLayer6}"
                        Click="Click_Six">
                    <TextBlock Text="6"
                               Style="{StaticResource Font_ButtonSign}" />
                </Button>

                <Button Grid.Row="3"
                        Grid.Column="0"
                        Margin="2"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        Style="{StaticResource Style_ButtonLayer6}"
                        Click="Click_One">
                    <TextBlock Text="1"
                               Style="{StaticResource Font_ButtonSign}" />
                </Button>
                <Button Grid.Row="3"
                        Grid.Column="1"
                        Margin="2"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        Style="{StaticResource Style_ButtonLayer6}"
                        Click="Click_Two">
                    <TextBlock Text="2"
                               Style="{StaticResource Font_ButtonSign}" />
                </Button>
                <Button Grid.Row="3"
                        Grid.Column="2"
                        Margin="2"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        Style="{StaticResource Style_ButtonLayer6}"
                        Click="Click_Three">
                    <TextBlock Text="3"
                               Style="{StaticResource Font_ButtonSign}" />
                </Button>

                <Button Grid.Row="4"
                        Grid.Column="0"
                        Margin="2"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        Style="{StaticResource Style_ButtonLayer6}"
                        Click="Click_DecimalPoint">
                    <TextBlock Text="."
                               Style="{StaticResource Font_ButtonSign}" />
                </Button>
                <Button Grid.Row="4"
                        Grid.Column="1"
                        Margin="2"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        Style="{StaticResource Style_ButtonLayer6}"
                        Click="Click_Zero">
                    <TextBlock Text="0"
                               Style="{StaticResource Font_ButtonSign}" />
                </Button>
                <Button Grid.Row="4"
                        Grid.Column="2"
                        Margin="2"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        Style="{StaticResource Style_ButtonAccent1}"
                        Click="Click_Calculate">
                    <TextBlock Text="="
                               Style="{StaticResource Font_ButtonSign}" />
                </Button>
            </Grid>


            <Border Grid.Row="2"
                    Grid.RowSpan="5"
                    Grid.Column="0"
                    Grid.ColumnSpan="3"
                    Margin="2"
                    Canvas.ZIndex="10"
                    CornerRadius="6"
                    BorderThickness="0.4"
                    BorderBrush="Black"
                    Visibility="Collapsed"
                    Background="{StaticResource Brush_Layer4}"
                    x:Name="Border_SelectionCurrency1">

                <ScrollViewer Margin="2,2,4,4">
                    <Grid Height="220">
                        <Grid.Resources>
                            <StaticResource x:Key="ButtonBackgroundPointerOver"
                                            ResourceKey="Brush_Layer5_5" />
                            <StaticResource x:Key="ButtonBackgroundPressed"
                                            ResourceKey="Brush_Layer4" />
                        </Grid.Resources>
                        <Grid.RowDefinitions>
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                        </Grid.RowDefinitions>

                        <Button Grid.Row="0"
                                Margin="2,2,4,2"
                                Visibility="Visible"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left"
                                Style="{StaticResource Style_ButtonLayer6}"
                                x:Name="Button_Currency1EuroEnabled"
                                Click="Click_CurrencyEuro">
                            <Button.Resources>
                                <StaticResource x:Key="ButtonBackgroundPointerOver"
                                                ResourceKey="Brush_Layer7" />
                                <StaticResource x:Key="ButtonBackgroundPressed"
                                                ResourceKey="Brush_Layer5" />
                            </Button.Resources>
                            <StackPanel Orientation="Horizontal">
                                <Border Height="17"
                                        Width="5"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Left"
                                        Background="{StaticResource Brush_Accent1}"
                                        CornerRadius="2" />
                                <TextBlock Text="Europe-Euro"
                                           Margin="10,1,0,0"
                                           Style="{StaticResource Font_SelectionBorderButton}" />
                            </StackPanel>
                        </Button>
                        <Button Grid.Row="0"
                                Margin="2,2,4,2"
                                Visibility="Collapsed"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left"
                                Style="{StaticResource Style_ButtonLayer4_5}"
                                x:Name="Button_Currency1EuroDisabled"
                                Click="Click_CurrencyEuro">
                            <StackPanel Orientation="Horizontal">
                                <Border Height="17"
                                        Width="5"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Left"
                                        Background="Transparent"
                                        CornerRadius="2" />
                                <TextBlock Text="Europe-Euro"
                                           Margin="10,1,0,0"
                                           Style="{StaticResource Font_SelectionBorderButton}" />
                            </StackPanel>
                        </Button>

                        <Button Grid.Row="1"
                                Margin="2,2,4,2"
                                Visibility="Collapsed"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left"
                                Style="{StaticResource Style_ButtonLayer6}"
                                x:Name="Button_Currency1DollarEnabled"
                                Click="Click_CurrencyDollar">
                            <Button.Resources>
                                <StaticResource x:Key="ButtonBackgroundPointerOver"
                                                ResourceKey="Brush_Layer7" />
                                <StaticResource x:Key="ButtonBackgroundPressed"
                                                ResourceKey="Brush_Layer5" />
                            </Button.Resources>
                            <StackPanel Orientation="Horizontal">
                                <Border Height="17"
                                        Width="5"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Left"
                                        Background="{StaticResource Brush_Accent1}"
                                        CornerRadius="2" />
                                <TextBlock Text="United States-Dollar"
                                           Margin="10,1,0,0"
                                           Style="{StaticResource Font_SelectionBorderButton}" />
                            </StackPanel>
                        </Button>
                        <Button Grid.Row="1"
                                Margin="2,2,4,2"
                                Visibility="Visible"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left"
                                Style="{StaticResource Style_ButtonLayer4_5}"
                                x:Name="Button_Currency1DollarDisabled"
                                Click="Click_CurrencyDollar">
                            <StackPanel Orientation="Horizontal">
                                <Border Height="17"
                                        Width="5"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Left"
                                        Background="Transparent"
                                        CornerRadius="2" />
                                <TextBlock Text="United States-Dollar"
                                           Margin="10,1,0,0"
                                           Style="{StaticResource Font_SelectionBorderButton}" />
                            </StackPanel>
                        </Button>

                        <Button Grid.Row="2"
                                Margin="2,2,4,2"
                                Visibility="Collapsed"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left"
                                Style="{StaticResource Style_ButtonLayer6}"
                                x:Name="Button_Currency1PoundEnabled"
                                Click="Click_CurrencyPound">
                            <Button.Resources>
                                <StaticResource x:Key="ButtonBackgroundPointerOver"
                                                ResourceKey="Brush_Layer7" />
                                <StaticResource x:Key="ButtonBackgroundPressed"
                                                ResourceKey="Brush_Layer5" />
                            </Button.Resources>
                            <StackPanel Orientation="Horizontal">
                                <Border Height="17"
                                        Width="5"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Left"
                                        Background="{StaticResource Brush_Accent1}"
                                        CornerRadius="2" />
                                <TextBlock Text="Great Britain-Pound"
                                           Margin="10,1,0,0"
                                           Style="{StaticResource Font_SelectionBorderButton}" />
                            </StackPanel>
                        </Button>
                        <Button Grid.Row="2"
                                Margin="2,2,4,2"
                                Visibility="Visible"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left"
                                Style="{StaticResource Style_ButtonLayer4_5}"
                                x:Name="Button_Currency1PoundDisabled"
                                Click="Click_CurrencyPound">
                            <StackPanel Orientation="Horizontal">
                                <Border Height="17"
                                        Width="5"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Left"
                                        Background="Transparent"
                                        CornerRadius="2" />
                                <TextBlock Text="Great Britain-Pound"
                                           Margin="10,1,0,0"
                                           Style="{StaticResource Font_SelectionBorderButton}" />
                            </StackPanel>
                        </Button>

                        <Button Grid.Row="3"
                                Margin="2,2,4,2"
                                Visibility="Collapsed"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left"
                                Style="{StaticResource Style_ButtonLayer6}"
                                x:Name="Button_Currency1KorunaEnabled"
                                Click="Click_CurrencyKoruna">
                            <Button.Resources>
                                <StaticResource x:Key="ButtonBackgroundPointerOver"
                                                ResourceKey="Brush_Layer7" />
                                <StaticResource x:Key="ButtonBackgroundPressed"
                                                ResourceKey="Brush_Layer5" />
                            </Button.Resources>
                            <StackPanel Orientation="Horizontal">
                                <Border Height="17"
                                        Width="5"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Left"
                                        Background="{StaticResource Brush_Accent1}"
                                        CornerRadius="2" />
                                <TextBlock Text="Czech Republic-Koruna"
                                           Margin="10,1,0,0"
                                           Style="{StaticResource Font_SelectionBorderButton}" />
                            </StackPanel>
                        </Button>
                        <Button Grid.Row="3"
                                Margin="2,2,4,2"
                                Visibility="Visible"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left"
                                Style="{StaticResource Style_ButtonLayer4_5}"
                                x:Name="Button_Currency1KorunaDisabled"
                                Click="Click_CurrencyKoruna">
                            <StackPanel Orientation="Horizontal">
                                <Border Height="17"
                                        Width="5"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Left"
                                        Background="Transparent"
                                        CornerRadius="2" />
                                <TextBlock Text="Czech Republic-Koruna"
                                           Margin="10,1,0,0"
                                           Style="{StaticResource Font_SelectionBorderButton}" />
                            </StackPanel>
                        </Button>

                        <Button Grid.Row="4"
                                Margin="2,2,4,2"
                                Visibility="Collapsed"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left"
                                Style="{StaticResource Style_ButtonLayer6}"
                                x:Name="Button_Currency1YenEnabled"
                                Click="Click_CurrencyYen">
                            <Button.Resources>
                                <StaticResource x:Key="ButtonBackgroundPointerOver"
                                                ResourceKey="Brush_Layer7" />
                                <StaticResource x:Key="ButtonBackgroundPressed"
                                                ResourceKey="Brush_Layer5" />
                            </Button.Resources>
                            <StackPanel Orientation="Horizontal">
                                <Border Height="17"
                                        Width="5"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Left"
                                        Background="{StaticResource Brush_Accent1}"
                                        CornerRadius="2" />
                                <TextBlock Text="Japan-Yen"
                                           Margin="10,1,0,0"
                                           Style="{StaticResource Font_SelectionBorderButton}" />
                            </StackPanel>
                        </Button>
                        <Button Grid.Row="4"
                                Margin="2,2,4,2"
                                Visibility="Visible"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left"
                                Style="{StaticResource Style_ButtonLayer4_5}"
                                x:Name="Button_Currency1YenDisabled"
                                Click="Click_CurrencyYen">
                            <StackPanel Orientation="Horizontal">
                                <Border Height="17"
                                        Width="5"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Left"
                                        Background="Transparent"
                                        CornerRadius="2" />
                                <TextBlock Text="Japan-Yen"
                                           Margin="10,1,0,0"
                                           Style="{StaticResource Font_SelectionBorderButton}" />
                            </StackPanel>
                        </Button>

                        <Button Grid.Row="5"
                                Margin="2,2,4,2"
                                Visibility="Collapsed"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left"
                                Style="{StaticResource Style_ButtonLayer6}"
                                x:Name="Button_Currency1YuanEnabled"
                                Click="Click_CurrencyYuan">
                            <Button.Resources>
                                <StaticResource x:Key="ButtonBackgroundPointerOver"
                                                ResourceKey="Brush_Layer7" />
                                <StaticResource x:Key="ButtonBackgroundPressed"
                                                ResourceKey="Brush_Layer5" />
                            </Button.Resources>
                            <StackPanel Orientation="Horizontal">
                                <Border Height="17"
                                        Width="5"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Left"
                                        Background="{StaticResource Brush_Accent1}"
                                        CornerRadius="2" />
                                <TextBlock Text="China-Yuan"
                                           Margin="10,1,0,0"
                                           Style="{StaticResource Font_SelectionBorderButton}" />
                            </StackPanel>
                        </Button>
                        <Button Grid.Row="5"
                                Margin="2,2,4,2"
                                Visibility="Visible"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left"
                                Style="{StaticResource Style_ButtonLayer4_5}"
                                x:Name="Button_Currency1YuanDisabled"
                                Click="Click_CurrencyYuan">
                            <StackPanel Orientation="Horizontal">
                                <Border Height="17"
                                        Width="5"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Left"
                                        Background="Transparent"
                                        CornerRadius="2" />
                                <TextBlock Text="China-Yuan"
                                           Margin="10,1,0,0"
                                           Style="{StaticResource Font_SelectionBorderButton}" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </ScrollViewer>
            </Border>

            <Border Grid.Row="4"
                    Grid.RowSpan="3"
                    Grid.Column="0"
                    Grid.ColumnSpan="3"
                    Margin="2"
                    Canvas.ZIndex="10"
                    CornerRadius="6"
                    BorderThickness="0.4"
                    BorderBrush="Black"
                    Visibility="Collapsed"
                    Background="{StaticResource Brush_Layer4}"
                    x:Name="Border_SelectionCurrency2">

                <ScrollViewer Margin="2,2,4,4">
                    <Grid Height="220">
                        <Grid.Resources>
                            <StaticResource x:Key="ButtonBackgroundPointerOver"
                                            ResourceKey="Brush_Layer5_5" />
                            <StaticResource x:Key="ButtonBackgroundPressed"
                                            ResourceKey="Brush_Layer4" />
                        </Grid.Resources>
                        <Grid.RowDefinitions>
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                        </Grid.RowDefinitions>

                        <Button Grid.Row="0"
                                Margin="2,2,4,2"
                                Visibility="Collapsed"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left"
                                Style="{StaticResource Style_ButtonLayer6}"
                                x:Name="Button_Currency2EuroEnabled"
                                Click="Click_CurrencyEuro">
                            <Button.Resources>
                                <StaticResource x:Key="ButtonBackgroundPointerOver"
                                                ResourceKey="Brush_Layer7" />
                                <StaticResource x:Key="ButtonBackgroundPressed"
                                                ResourceKey="Brush_Layer5" />
                            </Button.Resources>
                            <StackPanel Orientation="Horizontal">
                                <Border Height="17"
                                        Width="5"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Left"
                                        Background="{StaticResource Brush_Accent1}"
                                        CornerRadius="2" />
                                <TextBlock Text="Europe-Euro"
                                           Margin="10,1,0,0"
                                           Style="{StaticResource Font_SelectionBorderButton}" />
                            </StackPanel>
                        </Button>
                        <Button Grid.Row="0"
                                Margin="2,2,4,2"
                                Visibility="Visible"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left"
                                Style="{StaticResource Style_ButtonLayer4_5}"
                                x:Name="Button_Currency2EuroDisabled"
                                Click="Click_CurrencyEuro">
                            <StackPanel Orientation="Horizontal">
                                <Border Height="17"
                                        Width="5"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Left"
                                        Background="Transparent"
                                        CornerRadius="2" />
                                <TextBlock Text="Europe-Euro"
                                           Margin="10,1,0,0"
                                           Style="{StaticResource Font_SelectionBorderButton}" />
                            </StackPanel>
                        </Button>

                        <Button Grid.Row="1"
                                Margin="2,2,4,2"
                                Visibility="Visible"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left"
                                Style="{StaticResource Style_ButtonLayer6}"
                                x:Name="Button_Currency2DollarEnabled"
                                Click="Click_CurrencyDollar">
                            <Button.Resources>
                                <StaticResource x:Key="ButtonBackgroundPointerOver"
                                                ResourceKey="Brush_Layer7" />
                                <StaticResource x:Key="ButtonBackgroundPressed"
                                                ResourceKey="Brush_Layer5" />
                            </Button.Resources>
                            <StackPanel Orientation="Horizontal">
                                <Border Height="17"
                                        Width="5"
