<Page
    x:Class="Calculator.Pages.Standard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Calculator.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Standard"
    d:DesignHeight="500"
    d:DesignWidth="300"
    mc:Ignorable="d">

    <Border Background="{StaticResource Brush_Layer3}">
        <Grid Margin="5">
            <Grid.RowDefinitions>

                <!--  Header  -->
                <RowDefinition Height="50" />

                <!--  Output Display  -->
                <RowDefinition Height="120*" />

                <!--  Input Buttons  -->
                <RowDefinition Height="50*" />
                <RowDefinition Height="50*" />
                <RowDefinition Height="50*" />
                <RowDefinition Height="50*" />
                <RowDefinition Height="50*" />
                <RowDefinition Height="50*" />
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition />
                <ColumnDefinition />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>

            <!--  Header  -->
            <!--  Menu Button  -->
            <Button
                Grid.Row="0"
                Grid.Column="0"
                Width="45"
                Height="40"
                Margin="2"
                HorizontalAlignment="Left"
                Click="Click_Menu"
                Style="{DynamicResource Style_ButtonLayer3_5}">

                <StackPanel>
                    <Image
                        Width="25"
                        Height="25"
                        Source="/Icons/menu.png" />
                </StackPanel>
            </Button>

            <!--  Title  -->
            <TextBlock
                Grid.Row="0"
                Grid.Column="0"
                Grid.ColumnSpan="4"
                Margin="55,0,0,0"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                Style="{StaticResource Font_TextBlockHeader}"
                Text="Standard" />

            <!--  Output Display  -->
            <ScrollViewer
                x:Name="outputScrollviewer"
                Grid.Row="1"
                Grid.Column="0"
                Grid.ColumnSpan="4"
                Margin="2"
                HorizontalScrollBarVisibility="Visible"
                VerticalScrollBarVisibility="Disabled">

                <ScrollViewer.Resources>
                    <Style BasedOn="{StaticResource customscrollbar}" TargetType="ScrollBar" />
                </ScrollViewer.Resources>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="30*" />
                        <RowDefinition Height="60*" />
                        <RowDefinition Height="5*" />
                    </Grid.RowDefinitions>

                    <!--  Display2  -->
                    <TextBlock
                        x:Name="TextBlock_Calculation"
                        Grid.Row="0"
                        Margin="5,0,5,0"
                        HorizontalAlignment="Right"
                        FontSize="18"
                        FontWeight="Normal"
                        Foreground="Gray"
                        Style="{StaticResource Font_TextBlockOutputDisplay}"
                        Text="" />

                    <!--  Display1  -->
                    <TextBlock
                        x:Name="TextBlock_InputAndResult"
                        Grid.Row="1"
                        Margin="5,0,5,0"
                        HorizontalAlignment="Right"
                        FontSize="50"
                        Foreground="White"
                        Style="{StaticResource Font_TextBlockOutputDisplay}"
                        Text="0" />
                </Grid>
            </ScrollViewer>

            <!--  Input Buttons  -->
            <Button
                Grid.Row="2"
                Grid.Column="0"
                Margin="2"
                Click="Click_BracketLeft"
                Style="{StaticResource Style_ButtonLayer5}">

                <TextBlock
                    HorizontalAlignment="Center"
                    Style="{StaticResource Font_ButtonSign}"
                    Text="(" />
            </Button>

            <Button
                Grid.Row="2"
                Grid.Column="1"
                Margin="2"
                Click="Click_BracketRight"
                Style="{StaticResource Style_ButtonLayer5}">

                <TextBlock
                    HorizontalAlignment="Center"
                    Style="{StaticResource Font_ButtonSign}"
                    Text=")" />
            </Button>

            <Button
                Grid.Row="2"
                Grid.Column="2"
                Margin="2"
                Click="Click_ClearAllInput"
                Style="{StaticResource Style_ButtonLayer5}">

                <TextBlock
                    HorizontalAlignment="Center"
                    Style="{StaticResource Font_ButtonSign}"
                    Text="CE" />
            </Button>

            <Button
                Grid.Row="2"
                Grid.Column="3"
                Margin="2"
                Click="Click_Backspace"
                Style="{StaticResource Style_ButtonLayer5}">

                <Image
                    Width="22"
                    Height="22"
                    Source="/Icons/backspace.png" />
            </Button>

            <Button
                Grid.Row="3"
                Grid.Column="0"
                Margin="2"
                Click="Click_Power1"
                Style="{StaticResource Style_ButtonLayer5}">

                <TextBlock
                    HorizontalAlignment="Center"
                    Style="{StaticResource Font_ButtonSign}"
                    Text="^2" />
            </Button>

            <Button
                Grid.Row="3"
                Grid.Column="1"
                Margin="2"
                Click="CLick_Power2"
                Style="{StaticResource Style_ButtonLayer5}">

                <TextBlock
                    HorizontalAlignment="Center"
                    Style="{StaticResource Font_ButtonSign}"
                    Text="^" />
            </Button>

            <Button
                Grid.Row="3"
                Grid.Column="2"
                Margin="2"
                Click="Click_Root1"
                Style="{StaticResource Style_ButtonLayer5}">

                <TextBlock
                    HorizontalAlignment="Center"
                    Style="{StaticResource Font_ButtonSign}"
                    Text="2√" />
            </Button>

            <Button
                Grid.Row="3"
                Grid.Column="3"
                Margin="2"
                Click="Click_Root2"
                Style="{StaticResource Style_ButtonLayer5}">

                <TextBlock
                    HorizontalAlignment="Center"
                    Style="{StaticResource Font_ButtonSign}"
                    Text="√" />
            </Button>

            <Button
                Grid.Row="4"
                Grid.Column="0"
                Margin="2"
                Click="Click_Seven"
                Style="{StaticResource Style_ButtonLayer6}">

                <TextBlock
                    FontSize="18"
                    Style="{StaticResource Font_ButtonSign}"
                    Text="7" />
            </Button>

            <Button
                Grid.Row="4"
                Grid.Column="1"
                Margin="2"
                Click="Click_Eight"
                Style="{StaticResource Style_ButtonLayer6}">

                <TextBlock
                    HorizontalAlignment="Center"
                    Style="{StaticResource Font_ButtonSign}"
                    Text="8" />
            </Button>

            <Button
                Grid.Row="4"
                Grid.Column="2"
                Margin="2"
                Click="Click_Nine"
                Style="{StaticResource Style_ButtonLayer6}">

                <TextBlock
                    HorizontalAlignment="Center"
                    Style="{StaticResource Font_ButtonSign}"
                    Text="9" />
            </Button>

            <Button
                Grid.Row="4"
                Grid.Column="3"
                Margin="2"
                Click="Click_Divide"
                Style="{StaticResource Style_ButtonLayer5}">

                <TextBlock
                    HorizontalAlignment="Center"
                    Style="{StaticResource Font_ButtonSign}"
                    Text="/" />
            </Button>

            <Button
                Grid.Row="5"
                Grid.Column="0"
                Margin="2"
                Click="Click_Four"
                Style="{StaticResource Style_ButtonLayer6}">

                <TextBlock
                    HorizontalAlignment="Center"
                    Style="{StaticResource Font_ButtonSign}"
                    Text="4" />
            </Button>

            <Button
                Grid.Row="5"
                Grid.Column="1"
                Margin="2"
                Click="Click_Five"
                Style="{StaticResource Style_ButtonLayer6}">

                <TextBlock
                    HorizontalAlignment="Center"
                    Style="{StaticResource Font_ButtonSign}"
                    Text="5" />
            </Button>

            <Button
                Grid.Row="5"
                Grid.Column="2"
                Margin="2"
                Click="Click_Six"
                Style="{StaticResource Style_ButtonLayer6}">

                <TextBlock
                    HorizontalAlignment="Center"
                    Style="{StaticResource Font_ButtonSign}"
                    Text="6" />
            </Button>

            <Button
                Grid.Row="5"
                Grid.Column="3"
                Margin="2"
                Click="Click_Multiply"
                Style="{StaticResource Style_ButtonLayer5}">

                <TextBlock
                    HorizontalAlignment="Center"
                    Style="{StaticResource Font_ButtonSign}"
                    Text="*" />
            </Button>

            <Button
                Grid.Row="6"
                Grid.Column="0"
                Margin="2"
                Click="Click_One"
                Style="{StaticResource Style_ButtonLayer6}">

                <TextBlock
                    HorizontalAlignment="Center"
                    Style="{StaticResource Font_ButtonSign}"
                    Text="1" />
            </Button>

            <Button
                Grid.Row="6"
                Grid.Column="1"
                Margin="2"
                Click="Click_Two"
                Style="{StaticResource Style_ButtonLayer6}">

                <TextBlock
                    HorizontalAlignment="Center"
                    Style="{StaticResource Font_ButtonSign}"
                    Text="2" />
            </Button>

            <Button
                Grid.Row="6"
                Grid.Column="2"
                Margin="2"
                Click="Click_Three"
                Style="{StaticResource Style_ButtonLayer6}">

                <TextBlock
                    HorizontalAlignment="Center"
                    Style="{StaticResource Font_ButtonSign}"
                    Text="3" />
            </Button>

            <Button
                Grid.Row="6"
                Grid.Column="3"
                Margin="2"
                Click="Click_Subtract"
                Style="{StaticResource Style_ButtonLayer5}">

                <TextBlock
                    HorizontalAlignment="Center"
                    Style="{StaticResource Font_ButtonSign}"
                    Text="-" />
            </Button>

            <Button
                Grid.Row="7"
                Grid.Column="0"
                Margin="2"
                Click="Click_DecimalPoint"
                Style="{StaticResource Style_ButtonLayer5}">

                <TextBlock
                    HorizontalAlignment="Center"
                    Style="{StaticResource Font_ButtonSign}"
                    Text="." />
            </Button>

            <Button
                Grid.Row="7"
                Grid.Column="1"
                Margin="2"
                Click="Click_Zero"
                Style="{StaticResource Style_ButtonLayer6}">

                <TextBlock
                    HorizontalAlignment="Center"
                    Style="{StaticResource Font_ButtonSign}"
                    Text="0" />
            </Button>

            <Button
                Grid.Row="7"
                Grid.Column="2"
                Margin="2"
                Click="Click_Add"
                Style="{StaticResource Style_ButtonLayer5}">

                <TextBlock
                    HorizontalAlignment="Center"
                    Style="{StaticResource Font_ButtonSign}"
                    Text="+" />
            </Button>

            <Button
                Grid.Row="7"
                Grid.Column="3"
                Margin="2"
                Click="Click_Calculate"
                Style="{StaticResource Style_ButtonAccent1}">

                <TextBlock
                    HorizontalAlignment="Center"
                    Style="{StaticResource Font_ButtonSign}"
                    Text="=" />
            </Button>
        </Grid>
    </Border>
</Page>
