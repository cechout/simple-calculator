                        <!--Koruna-->
                        <!--Enabled-->
                        <Button Grid.Row="3"
                                Margin="2, 2, 4, 2"
                                Visibility="Collapsed"
                                HorizontalContentAlignment="Left"
                                Style="{StaticResource Style_ButtonLayer6}"
                                x:Name="Button_Currency1KorunaEnabled"
                                Click="Click_CurrencyKoruna">

                            <StackPanel Orientation="Horizontal">
                                <Border Height="17"
                                        Width="5"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Left"
                                        Background="{StaticResource Brush_Accent1}"
                                        CornerRadius="2" />

                                <TextBlock Text="Czech Republic-Koruna"  
                                           Margin="10, 1, 0, 0"
                                           Style="{StaticResource Font_SelectionBorderButton}"/>
                            </StackPanel>
                        </Button>

                        <!--Disabled-->
                        <Button Grid.Row="3"
                                Margin="2, 2, 4, 2"
                                Visibility="Visible"
                                HorizontalContentAlignment="Left"
                                Style="{StaticResource Style_ButtonLayer4_5}"
                                x:Name="Button_Currency1KorunaDisabled"
                                Click="Click_CurrencyKoruna">

                            <StackPanel Orientation="Horizontal">
                                <Border Height="17"
                                        Width="5"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Left"
                                        Background="Transparent"
                                        CornerRadius="2" />

                                <TextBlock Text="Czech Republic-Koruna"  
                                           Margin="10, 1, 0, 0"
                                           Style="{StaticResource Font_SelectionBorderButton}"/>
                            </StackPanel>
                        </Button>

                        <!--Yen-->
                        <!--Enabled-->
                        <Button Grid.Row="4"
                                Margin="2, 2, 4, 2"
                                Visibility="Collapsed"
                                HorizontalContentAlignment="Left"
                                Style="{StaticResource Style_ButtonLayer6}"
                                x:Name="Button_Currency1YenEnabled"
                                Click="Click_CurrencyYen">

                            <StackPanel Orientation="Horizontal">
                                <Border Height="17"
                                        Width="5"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Left"
                                        Background="{StaticResource Brush_Accent1}"
                                        CornerRadius="2" />

                                <TextBlock Text="Japan-Yen"  
                                           Margin="10, 1, 0, 0"
                                           Style="{StaticResource Font_SelectionBorderButton}"/>
                            </StackPanel>
                        </Button>

                        <!--Disabled-->
                        <Button Grid.Row="4"
                                Margin="2, 2, 4, 2"
                                Visibility="Visible"
