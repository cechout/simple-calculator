                        <!--Disabled-->
                        <Button Grid.Row="4"
                                Margin="2, 2, 4, 2"
                                Visibility="Visible"
                                HorizontalContentAlignment="Left"
                                Style="{StaticResource Style_ButtonLayer4_5}"
                                x:Name="Button_Currency2YenDisabled"
                                Click="Click_CurrencyYen">

                            <StackPanel Orientation="Horizontal">
                                <Border Height="17"
                                        Width="5"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Left"
                                        Background="Transparent"
                                        CornerRadius="2" />

                                <TextBlock Text="Japan-Yen"  
                                           Margin="10, 1, 0, 0"
                                           Style="{StaticResource Font_SelectionBorderButton}"/>
                            </StackPanel>
                        </Button>

                        <!--Yuan-->
                        <!--Enabled-->
                        <Button Grid.Row="5"
                                Margin="2, 2, 4, 2"
                                Visibility="Collapsed"
                                HorizontalContentAlignment="Left"
                                Style="{StaticResource Style_ButtonLayer6}"
                                x:Name="Button_Currency2YuanEnabled"
                                Click="Click_CurrencyYuan">

                            <StackPanel Orientation="Horizontal">
                                <Border Height="17"
                                        Width="5"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Left"
                                        Background="{StaticResource Brush_Accent1}"
                                        CornerRadius="2" />

                                <TextBlock Text="China-Yuan"  
                                           Margin="10, 1, 0, 0"
                                           Style="{StaticResource Font_SelectionBorderButton}"/>
                            </StackPanel>
                        </Button>

                        <!--Disabled-->
                        <Button Grid.Row="5"
                                Margin="2, 2, 4, 2"
                                Visibility="Visible"
                                HorizontalContentAlignment="Left"
                                Style="{StaticResource Style_ButtonLayer4_5}"
                                x:Name="Button_Currency2YuanDisabled"
                                Click="Click_CurrencyYuan">

                            <StackPanel Orientation="Horizontal">
                                <Border Height="17"
                                        Width="5"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Left"
                                        Background="Transparent"
                                        CornerRadius="2" />

                                <TextBlock Text="China-Yuan"  
                                           Margin="10, 1, 0, 0"
                                           Style="{StaticResource Font_SelectionBorderButton}"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </ScrollViewer>
            </Border>
        </Grid>
    </Border>
</Page>
