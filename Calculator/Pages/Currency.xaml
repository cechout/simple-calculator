                        <!--Disabled-->
                        <Button Grid.Row="1"
                                Margin="2, 2, 4, 2"
                                Visibility="Visible"
                                HorizontalContentAlignment="Left"
                                Style="{StaticResource Style_ButtonLayer4_5}"
                                x:Name="Button_Currency1DollarDisabled"
