<Page x:Class="Calculator.Pages.Currency"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Calculator.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="500" d:DesignWidth="300"
      Title="Currency"
      Loaded="Page_Loaded">

    <Border Background="{StaticResource Brush_Layer3}">
        <Grid Margin="5">
            <Grid.RowDefinitions>

                <!--Header-->
                <RowDefinition Height="50" />

                <!--Output Displays-->
                <RowDefinition Height="30" />
                <RowDefinition Height="80*" />
                <RowDefinition Height="30" />
                <RowDefinition Height="80*" />
                <RowDefinition Height="30" />

                <!--Input Buttons-->
                <RowDefinition Height="50*" />
                <RowDefinition Height="50*" />
                <RowDefinition Height="50*" />
                <RowDefinition Height="50*" />
                <RowDefinition Height="50*" />
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>

            <!--Header-->
            <!--Menu Button-->
            <Button Grid.Row="0"
                    Grid.Column="0"
                    Margin="2"
                    Height="40"
                    Width="45"
                    HorizontalAlignment="Left"
                    Style="{DynamicResource Style_ButtonLayer3_5}"
                    Click="MenuClick">

                <StackPanel>
                    <Image Source="/Icons/GeneralIcons/menu.png"
                           Height="25"
                           Width="25" />
                </StackPanel>
            </Button>

            <!--Title-->
            <TextBlock Grid.Row="0"
                       Grid.Column="0"
                       Grid.ColumnSpan="4"
                       Margin="55, 5, 5, 5"
                       Text="Currency"                      
                       HorizontalAlignment="Left"
                       VerticalAlignment="Center"
                       Style="{StaticResource Font_TextBlockHeader}"/>

            <!--Output Displays-->
            <!--Selection Currency1 Button-->
            <Button Grid.Row="1"
                    Grid.Column="0"
                    Grid.ColumnSpan="3"
                    Margin="2"
                    HorizontalContentAlignment="Right"
                    Style="{DynamicResource Style_ButtonLayer3_5}"
                    Click="Click_SelectionCurrency1">

                <TextBlock Margin="0, 0, 7, 0"
                           Text="Europe-Euro"                           
                           Foreground="Gray"
                           Style="{StaticResource Font_SelectionButton}"
                           x:Name="TextBlock_SelectedCurrency1"/>
            </Button>

            <!--Display1-->
            <ScrollViewer Grid.Row="2"
              Grid.Column="0"
              Grid.ColumnSpan="3"
              Margin="2"
              VerticalScrollBarVisibility="Disabled"
              HorizontalScrollBarVisibility="Visible"                          >

                <ScrollViewer.Resources>
                    <Style TargetType="ScrollBar" BasedOn="{StaticResource customscrollbar}"/>
                </ScrollViewer.Resources>

                <TextBlock Margin="5, -3, 5, 0"
                           x:Name="TextBlock_Currency1"
                           Text="0"
                           Foreground="White"
                           FontSize="38"
                           HorizontalAlignment="Right"
                           Style="{StaticResource Font_TextBlockOutputDisplay}"/>
            </ScrollViewer>

            <!--Selection Currency2 Button-->
            <Button Grid.Row="3"
                    Grid.Column="0"
                    Grid.ColumnSpan="3"
                    Margin="2"
                    HorizontalContentAlignment="Right"
                    Style="{DynamicResource Style_ButtonLayer3_5}"
                    Click="Click_SelectionCurrency2">

                <TextBlock Margin="0, 0, 7, 0"
                           Text="United States-Dollar"                           
                           Foreground="Gray"
                           Style="{StaticResource Font_SelectionButton}"
                           x:Name="TextBlock_SelectedCurrency2"/>
            </Button>

            <!--Display2-->
            <ScrollViewer Grid.Row="4"
                          Grid.Column="0"
                          Grid.ColumnSpan="3"
                          Margin="2"
                          VerticalScrollBarVisibility="Disabled"
                          HorizontalScrollBarVisibility="Visible"                          >

                <ScrollViewer.Resources>
                    <Style TargetType="ScrollBar" BasedOn="{StaticResource customscrollbar}"/>
                </ScrollViewer.Resources>

                <TextBlock Margin="5, -3, 5, 0"
                           x:Name="TextBlock_Currency2"
                           Text="0"
                           FontWeight="DemiBold"
                           FontFamily="Montserrat"
                           Foreground="White"
                           FontSize="38"
                           HorizontalAlignment="Right"/>
            </ScrollViewer>

            <!--Conversion Number-->
            <Border Grid.Row="5"
                    Grid.Column="0"
                    Grid.ColumnSpan="3"
                    Margin="2"                    
                    Background="{StaticResource Brush_Layer3}">

                <TextBlock Margin="0, 0, 7, 0"
                           Text="1 EUR = 1.08 USD"                           
                           Foreground="{StaticResource Brush_Accent1}"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"
                           Style="{StaticResource Font_SelectionButton}"
                           x:Name="TextBlock_CurrencyRate"/>
            </Border>

            <!--Input Buttons-->
            <Button Grid.Row="6"
                    Grid.Column="0"
                    Margin="2"
                    Style="{StaticResource Style_ButtonLayer5}"
                    Click="Click_Refresh">

                <Image Height="22"
                       Width="22"
                       Source="/Icons/GeneralIcons/synchrosize.png" />
            </Button>

            <Button Grid.Row="6"
                    Grid.Column="1"
                    Margin="2"
                    Style="{StaticResource Style_ButtonLayer5}"
                    Click="Click_ClearAllInput">

                <TextBlock Text="CE"                           
                           Style="{StaticResource Font_ButtonSign}"/>
            </Button>

            <Button Grid.Row="6"
                    Grid.Column="2"
                    Margin="2"
                    Style="{StaticResource Style_ButtonLayer5}"
                    Click="Click_Backspace">

                <Image Height="22"
                       Width="22"
                       Source="/Icons/GeneralIcons/backspace.png" />
            </Button>

            <Button Grid.Row="7"
                    Grid.Column="0"
                    Margin="2"
                    Style="{StaticResource Style_ButtonLayer6}"
                    Click="Click_Seven">

                <TextBlock Text="7"                           
                           Style="{StaticResource Font_ButtonSign}"/>
            </Button>

            <Button Grid.Row="7"
                    Grid.Column="1"
                    Margin="2"
                    Style="{StaticResource Style_ButtonLayer6}"
                    Click="Click_Eight">

                <TextBlock Text="8"                           
                           Style="{StaticResource Font_ButtonSign}"/>
            </Button>

            <Button Grid.Row="7"
                    Grid.Column="2"
                    Margin="2"
                    Style="{StaticResource Style_ButtonLayer6}"
                    Click="Click_Nine">

                <TextBlock Text="9"                           
                           Style="{StaticResource Font_ButtonSign}"/>
            </Button>

            <Button Grid.Row="8"
                    Grid.Column="0"
                    Margin="2"
                    Style="{StaticResource Style_ButtonLayer6}"
                    Click="Click_Four">

                <TextBlock Text="4"                           
                           Style="{StaticResource Font_ButtonSign}"/>
            </Button>

            <Button Grid.Row="8"
                    Grid.Column="1"
                    Margin="2"
                    Style="{StaticResource Style_ButtonLayer6}"
                    Click="Click_Five">

                <TextBlock Text="5"                           
                           Style="{StaticResource Font_ButtonSign}"/>
            </Button>

            <Button Grid.Row="8"
                    Grid.Column="2"
                    Margin="2"
                    Style="{StaticResource Style_ButtonLayer6}"
                    Click="Click_Six">

                <TextBlock Text="6"                           
                           Style="{StaticResource Font_ButtonSign}"/>
            </Button>

            <Button Grid.Row="9"
                    Grid.Column="0"
                    Margin="2"
                    Style="{StaticResource Style_ButtonLayer6}"
                    Click="Click_One">

                <TextBlock Text="1"                           
                           Style="{StaticResource Font_ButtonSign}"/>
            </Button>

            <Button Grid.Row="9"
                    Grid.Column="1"
                    Margin="2"
                    Style="{StaticResource Style_ButtonLayer6}"
                    Click="Click_Two">

                <TextBlock Text="2"                           
                           Style="{StaticResource Font_ButtonSign}"/>
            </Button>

            <Button Grid.Row="9"
                    Grid.Column="2"
                    Margin="2"
                    Style="{StaticResource Style_ButtonLayer6}"
                    Click="Click_Three">

                <TextBlock Text="3"                           
                           Style="{StaticResource Font_ButtonSign}"/>
            </Button>

            <Button Grid.Row="10"
                    Grid.Column="0"
                    Margin="2"
                    Style="{StaticResource Style_ButtonLayer5}"
                    Click="Click_DecimalPoint">

                <TextBlock Text="."                           
                           Style="{StaticResource Font_ButtonSign}"/>
            </Button>

            <Button Grid.Row="10"
                    Grid.Column="1"
                    Margin="2"
                    Style="{StaticResource Style_ButtonLayer6}"
                    Click="Click_Zero">

                <TextBlock Text="0"                           
                           Style="{StaticResource Font_ButtonSign}"/>
            </Button>

            <Button Grid.Row="10"
                    Grid.Column="2"
                    Margin="2"
                    Style="{StaticResource Style_ButtonAccent1}"
                    Click="Click_Calculate">

                <TextBlock Text="="                           
                           Style="{StaticResource Font_ButtonSign}"/>
            </Button>

            <!--Currency1 Selection Menu-->
            <Border Grid.Row="1"
                    Grid.RowSpan="3"
                    Grid.Column="0"
                    Grid.ColumnSpan="3"
                    Margin="2"
                    CornerRadius="6"
                    BorderThickness="0.4"
                    BorderBrush="Black"
                    Visibility="Collapsed"
                    Background="{StaticResource Brush_Layer4}"
                    x:Name="Border_SelectionCurrency1">

                <ScrollViewer Margin="2, 2, 4, 4">
                    <ScrollViewer.Resources>
                        <Style TargetType="ScrollBar" BasedOn="{StaticResource customscrollbar}"/>
                    </ScrollViewer.Resources>

                    <Grid Height="220">
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        
                        <!--Euro-->
                        <!--Enabled-->
                        <Button Grid.Row="0"
                                Margin="2, 2, 4, 2"
                                Visibility="Visible"
                                HorizontalContentAlignment="Left"
                                Style="{StaticResource Style_ButtonLayer6}"
                                x:Name="Button_Currency1EuroEnabled"
                                Click="Click_CurrencyEuro">

                            <StackPanel Orientation="Horizontal">
                                <Border Height="17"
                                        Width="5"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Left"
                                        Background="{StaticResource Brush_Accent1}"
                                        CornerRadius="2" />

                                <TextBlock Text="Europe-Euro"  
                                           Margin="10, 1, 0, 0"
                                           Style="{StaticResource Font_SelectionBorderButton}"/>
                            </StackPanel>
                        </Button>

                        <!--Disabled-->
                        <Button Grid.Row="0"
                                Margin="2, 2, 4, 2"
                                Visibility="Collapsed"
                                HorizontalContentAlignment="Left"
                                Style="{StaticResource Style_ButtonLayer4_5}"
                                x:Name="Button_Currency1EuroDisabled"
                                Click="Click_CurrencyEuro">

                            <StackPanel Orientation="Horizontal">
                                <Border Height="17"
                                        Width="5"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Left"
                                        Background="Transparent"
                                        CornerRadius="2" />

                                <TextBlock Text="Europe-Euro"  
                                           Margin="10, 1, 0, 0"
                                           Style="{StaticResource Font_SelectionBorderButton}"/>
                            </StackPanel>
                        </Button>

                        <!--Dollar-->
                        <!--Enabled-->
                        <Button Grid.Row="1"
                                Margin="2, 2, 4, 2"
                                Visibility="Collapsed"
                                HorizontalContentAlignment="Left"
                                Style="{StaticResource Style_ButtonLayer6}"
