                                <TextBlock Text="China-Yuan"  
                                           Margin="10, 1, 0, 0"
                                           Style="{StaticResource Font_SelectionBorderButton}"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </ScrollViewer>
            </Border>

            <!--Currency2 Selection Menu-->
            <Border Grid.Row="3"
                    Grid.RowSpan="3"
                    Grid.Column="0"
                    Grid.ColumnSpan="3"
                    Margin="2"
                    CornerRadius="6"
                    BorderThickness="0.4"
                    BorderBrush="Black"
