                    </ScrollViewer.Resources>

                    <Grid Height="220">
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>

                        <!--Euro-->
                        <!--Enabled-->
                        <Button Grid.Row="0"
                                Margin="2, 2, 4, 2"
                                Visibility="Collapsed"
                                HorizontalContentAlignment="Left"
                                Style="{StaticResource Style_ButtonLayer6}"
