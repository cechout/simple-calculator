                        <!--Dollar-->
                        <!--Enabled-->
                        <Button Grid.Row="1"
                                Margin="2, 2, 4, 2"
                                Visibility="Visible"
                                HorizontalContentAlignment="Left"
                                Style="{StaticResource Style_ButtonLayer6}"
                                x:Name="Button_Currency2DollarEnabled"
                                Click="Click_CurrencyDollar">

                            <StackPanel Orientation="Horizontal">
