                        <!--Yen-->
                        <!--Enabled-->
                        <Button Grid.Row="4"
                                Margin="2, 2, 4, 2"
                                Visibility="Collapsed"
                                HorizontalContentAlignment="Left"
                                Style="{StaticResource Style_ButtonLayer6}"
                                x:Name="Button_Currency2YenEnabled"
                                Click="Click_CurrencyYen">

                            <StackPanel Orientation="Horizontal">
                                <Border Height="17"
