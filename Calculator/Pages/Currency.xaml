                            <StackPanel Orientation="Horizontal">
                                <Border Height="17"
                                        Width="5"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Left"
                                        Background="Transparent"
                                        CornerRadius="2" />

                                <TextBlock Text="United States-Dollar"  
                                           Margin="10, 1, 0, 0"
                                           Style="{StaticResource Font_SelectionBorderButton}"/>
                            </StackPanel>
                        </Button>

                        <!--Pound-->
                        <!--Enabled-->
                        <Button Grid.Row="2"
                                Margin="2, 2, 4, 2"
                                Visibility="Collapsed"
                                HorizontalContentAlignment="Left"
                                Style="{StaticResource Style_ButtonLayer6}"
                                x:Name="Button_Currency2PoundEnabled"
                                Click="Click_CurrencyPound">

                            <StackPanel Orientation="Horizontal">
                                <Border Height="17"
                                        Width="5"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Left"
                                        Background="{StaticResource Brush_Accent1}"
                                        CornerRadius="2" />

                                <TextBlock Text="Great Britain-Pound"  
                                           Margin="10, 1, 0, 0"
                                           Style="{StaticResource Font_SelectionBorderButton}"/>
                            </StackPanel>
                        </Button>

                        <!--Disabled-->
                        <Button Grid.Row="2"
                                Margin="2, 2, 4, 2"
                                Visibility="Visible"
                                HorizontalContentAlignment="Left"
                                Style="{StaticResource Style_ButtonLayer4_5}"
                                x:Name="Button_Currency2PoundDisabled"
                                Click="Click_CurrencyPound">

                            <StackPanel Orientation="Horizontal">
                                <Border Height="17"
                                        Width="5"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Left"
                                        Background="Transparent"
                                        CornerRadius="2" />

                                <TextBlock Text="Great Britain-Pound"
                                           Margin="10, 1, 0, 0"
                                           Style="{StaticResource Font_SelectionBorderButton}"/>
                            </StackPanel>
                        </Button>

                        <!--Koruna-->
                        <!--Enabled-->
                        <Button Grid.Row="3"
                                Margin="2, 2, 4, 2"
                                Visibility="Collapsed"
                                HorizontalContentAlignment="Left"
                                Style="{StaticResource Style_ButtonLayer6}"
                                x:Name="Button_Currency2KorunaEnabled"
                                Click="Click_CurrencyKoruna">

                            <StackPanel Orientation="Horizontal">
                                <Border Height="17"
                                        Width="5"
                                        VerticalAlignment="Center"
