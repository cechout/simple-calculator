<Page x:Class="Calculator.Pages.Menu"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Calculator.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="500" d:DesignWidth="300"
      Title="Menu">

    <Border Background="{StaticResource Brush_Layer3}">
        <Grid Margin="5">
            <Grid.RowDefinitions>

                <!--Header-->
                <RowDefinition Height="50" />
                <RowDefinition Height="20" />

                <!--Navigation Buttons-->
                <RowDefinition Height="43" />
                <RowDefinition Height="43" />
                <RowDefinition Height="30" />
                <RowDefinition Height="*" />

            </Grid.RowDefinitions>

            <!--Header-->
            <!--Menu Button-->
            <Button Grid.Row="0"
                    Grid.Column="0"
                    Margin="2"
                    Height="40"
                    Width="45"
                    HorizontalAlignment="Left"
                    Click="Click_Menu"
                    Style="{DynamicResource Style_ButtonLayer3_5}">

                <StackPanel>
                    <Image Source="/Icons/GeneralIcons/menu.png"
                           Height="25"
                           Width="25" />
                </StackPanel>
            </Button>

            <!--Title-->
            <TextBlock Grid.Row="0"
                       Grid.Column="0"
                       Grid.ColumnSpan="4"
                       Margin="55, 5, 5, 5"
                       Text="Menu"                       
                       HorizontalAlignment="Left"
                       VerticalAlignment="Center"
                       Style="{StaticResource Font_TextBlockHeader}"/>

            <!--Navigation Buttons-->
            <!--Standard-->
            <Button Grid.Row="2"
                    Grid.Column="0"
                    Margin="2"
                    Visibility="Visible"
                    x:Name="Button_StandardEnabled"
                    HorizontalContentAlignment="Left"
                    Style="{StaticResource Style_ButtonLayer5}"
                    Click="CLick_Standard">

                <StackPanel Orientation="Horizontal">
                    <Border Height="19"
                            Width="5"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Left"
                            Background="{StaticResource Brush_Accent1}"
                            CornerRadius="2" />

                    <Image Source="/Icons/GeneralIcons/calculate.png"
                           HorizontalAlignment="Left"
                           Margin="7, 0, 0, 0"
                           Height="25"
                           Width="25" />

                    <TextBlock Margin="10, 5, 5, 5"
                               Text="Standard"                       
                               HorizontalAlignment="Left"
                               VerticalAlignment="Center"
                               Style="{StaticResource Font_ButtonText}"/>
                </StackPanel>
            </Button>

            <Button Grid.Row="2"
                    Grid.Column="0"
                    Margin="2"
                    Visibility="Collapsed"
                    x:Name="Button_StandardDisabled"
                    HorizontalContentAlignment="Left"
                    Style="{StaticResource Style_ButtonLayer3_5}"
                    Click="CLick_Standard">

                <StackPanel Orientation="Horizontal">
                    <Border Height="19"
                            Width="5"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Left"
                            Background="Transparent"
                            CornerRadius="2" />

                    <Image Source="/Icons/calculate.png"
                           HorizontalAlignment="Left"
                           Margin="7, 0, 0, 0"
                           Height="25"
                           Width="25" />

                    <TextBlock Margin="10, 5, 5, 5"
                               Text="Standard"                       
                               HorizontalAlignment="Left"
                               VerticalAlignment="Center"
                               Style="{StaticResource Font_ButtonText}"/>
                </StackPanel>
            </Button>

            <!--Currency-->
            <Button Grid.Row="3"
                    Grid.Column="0"
                    Margin="2"
                    Visibility="Collapsed"
                    x:Name="Button_CurrencyEnabled"
                    HorizontalContentAlignment="Left"
                    Style="{StaticResource Style_ButtonLayer5}"
                    Click="Click_Currency">

                <StackPanel Orientation="Horizontal">
                    <Border Height="19"
                            Width="5"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Left"
                            Background="{StaticResource Brush_Accent1}"
                            CornerRadius="2" />

                    <Image Source="/Icons/currency.png"
                           HorizontalAlignment="Left"
                           Margin="9, 0, 0, 0"
                           Height="21"
                           Width="21" />

                    <TextBlock Margin="12, 5, 5, 5"
                               Text="Currency"                       
                               HorizontalAlignment="Left"
                               VerticalAlignment="Center"
                               Style="{StaticResource Font_ButtonText}"/>
                </StackPanel>
            </Button>

            <Button Grid.Row="3"
                    Grid.Column="0"
                    Margin="2"
                    Visibility="Visible"
                    x:Name="Button_CurrencyDisabled"
                    HorizontalContentAlignment="Left"
                    Style="{StaticResource Style_ButtonLayer3_5}"
                    Click="Click_Currency">

                <StackPanel Orientation="Horizontal">
                    <Border Height="19"
                            Width="5"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Left"
                            Background="Transparent"
                            CornerRadius="2" />

                    <Image Source="/Icons/GeneralIcons/currency.png"
                           HorizontalAlignment="Left"
                           Margin="9, 0, 0, 0"
                           Height="21"
                           Width="21" />

                    <TextBlock Margin="12, 5, 5, 5"
                               Text="Currency"                       
                               HorizontalAlignment="Left"
                               VerticalAlignment="Center"
                               Style="{StaticResource Font_ButtonText}"/>
                </StackPanel>
            </Button>

            <!--Error Button-->
            <Button Grid.Row="4"
                    Margin="2"
                    Visibility="Collapsed"
                    x:Name="Button_ErrorMessage"
                    HorizontalContentAlignment="Left"
                    Style="{StaticResource Style_ButtonLayer3_5}">

                <TextBlock Grid.Row="0"
                           Margin="12, 0, 0, 0"
                           Text="No Internet Connection"
                           Foreground="Red"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Left"
                           Style="{StaticResource Font_SelectionButton}"/>
            </Button>
        </Grid>
    </Border>
</Page>
