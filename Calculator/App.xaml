<Application
    x:Class="Calculator.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:Calculator"
    StartupUri="MainWindow.xaml">
    <Application.Resources>

        <!--  Color Palette 1  -->
        <!--  Dark  -->
        <SolidColorBrush x:Key="Brush_Layer1" Color="#0c0c0c" />
        <SolidColorBrush x:Key="Brush_Layer2" Color="#161616" />
        <SolidColorBrush x:Key="Brush_Layer3" Color="#202020" />
        <SolidColorBrush x:Key="Brush_Layer3_5" Color="#252525" />
        <SolidColorBrush x:Key="Brush_Layer4" Color="#2a2a2a" />
        <SolidColorBrush x:Key="Brush_Layer4_5" Color="#2f2f2f" />
        <SolidColorBrush x:Key="Brush_Layer5" Color="#343434" />
        <SolidColorBrush x:Key="Brush_Layer5_5" Color="#393939" />
        <SolidColorBrush x:Key="Brush_Layer6" Color="#3e3e3e" />
        <SolidColorBrush x:Key="Brush_Layer7" Color="#484848" />
        <SolidColorBrush x:Key="Brush_Layer8" Color="#525252" />
        <SolidColorBrush x:Key="Brush_Layer9" Color="#5c5c5c" />
        <SolidColorBrush x:Key="Brush_Layer10" Color="#666666" />

        <!--  Accent1  -->
        <SolidColorBrush x:Key="Brush_Accent1Dark" Color="#0081d6" />
        <SolidColorBrush x:Key="Brush_Accent1" Color="#0091e6" />
        <SolidColorBrush x:Key="Brush_Accent1Light" Color="#15a6fb" />

        <!--  Accent2  -->
        <SolidColorBrush x:Key="Brush_Accent2Dark" Color="#00a843" />
        <SolidColorBrush x:Key="Brush_Accent2" Color="#00c853" />
        <SolidColorBrush x:Key="Brush_Accent2Light" Color="#15dd68" />

        <!--  Accent3  -->
        <SolidColorBrush x:Key="Brush_Accent3Dark" Color="#c32f1f" />
        <SolidColorBrush x:Key="Brush_Accent3" Color="#d32f2f" />
        <SolidColorBrush x:Key="Brush_Accent3Light" Color="#e84444" />


        <!--  Fonts  -->
        <!--  Button Text  -->
        <Style x:Key="Font_ButtonText" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Aptos" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="Normal" />
            <Setter Property="Foreground" Value="#fefefe" />
        </Style>

        <!--  Button Sign  -->
        <Style x:Key="Font_ButtonSign" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Aptos" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="Normal" />
            <Setter Property="Foreground" Value="#fefefe" />
        </Style>

        <!--  TextBlock Header  -->
        <Style x:Key="Font_TextBlockHeader" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Aptos" />
            <Setter Property="FontSize" Value="20" />
            <Setter Property="FontWeight" Value="DemiBold" />
            <Setter Property="Foreground" Value="#fefefe" />
        </Style>

        <!--  TextBlock OutputDisplay  -->
        <Style x:Key="Font_TextBlockOutputDisplay" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Aptos" />
            <Setter Property="FontWeight" Value="DemiBold" />
        </Style>

        <!--  Selection Button  -->
        <Style x:Key="Font_SelectionButton" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Aptos" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="Normal" />
        </Style>

        <!--  SelectionBorder Button  -->
        <Style x:Key="Font_SelectionBorderButton" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Aptos" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="Normal" />
            <Setter Property="Foreground" Value="#fefefe" />
        </Style>


        <!--  Button Styles  -->
        <!--  Accent 3  -->
        <Style x:Key="Style_ButtonAccent3" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Brush_Accent3}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource Brush_Accent3Light}" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{StaticResource Brush_Accent3Dark}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!--  Accent 2  -->
        <Style x:Key="Style_ButtonAccent2" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Brush_Accent2}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource Brush_Accent2Light}" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{StaticResource Brush_Accent2Dark}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!--  Accent 1  -->
        <Style x:Key="Style_ButtonAccent1" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Brush_Accent1}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource Brush_Accent1Light}" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{StaticResource Brush_Accent1Dark}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!--  Layer 6  -->
        <Style x:Key="Style_ButtonLayer6" TargetType="Button">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="{StaticResource Brush_Layer6}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource Brush_Layer7}" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{StaticResource Brush_Layer6}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!--  Layer 5  -->
        <Style x:Key="Style_ButtonLayer5" TargetType="Button">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="{StaticResource Brush_Layer5}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource Brush_Layer6}" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{StaticResource Brush_Layer5}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!--  Layer 4_5  -->
        <Style x:Key="Style_ButtonLayer4_5" TargetType="Button">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="{StaticResource Brush_Layer4}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource Brush_Layer5_5}" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{StaticResource Brush_Layer5}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!--  Layer 4  -->
        <Style x:Key="Style_ButtonLayer4" TargetType="Button">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="{StaticResource Brush_Layer4}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource Brush_Layer5}" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{StaticResource Brush_Layer4}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!--  Layer 3_5  -->
        <Style x:Key="Style_ButtonLayer3_5" TargetType="Button">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="{StaticResource Brush_Layer3}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource Brush_Layer4_5}" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{StaticResource Brush_Layer4}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!--  Layer 3  -->
        <Style x:Key="Style_ButtonLayer3" TargetType="Button">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="{StaticResource Brush_Layer3}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource Brush_Layer4}" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{StaticResource Brush_Layer3}" />
                </Trigger>
            </Style.Triggers>
        </Style>


        <!--  Other Objects  -->
        <!--  Textbox  -->
        <Style x:Key="Style_TextBoxLayer5" TargetType="TextBox">

            <!--  Font  -->
            <Setter Property="FontFamily" Value="Aptos" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="DemiBold" />
            <Setter Property="Foreground" Value="White" />

            <Setter Property="CaretBrush">
                <Setter.Value>
                    <SolidColorBrush Color="White" />
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TextBoxBase}">

                        <!--  Default Colors  -->
                        <Border
                            x:Name="Bd"
                            Background="{StaticResource Brush_Layer5}"
                            BorderBrush="{StaticResource Brush_Layer5}"
                            BorderThickness="3"
                            CornerRadius="6">
                            <ScrollViewer
                                x:Name="PART_ContentHost"
                                Focusable="False"
                                HorizontalScrollBarVisibility="Hidden"
                                VerticalScrollBarVisibility="Hidden" />
                        </Border>

                        <!--  Trigger Colors  -->
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="1" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource Brush_Layer5}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource Brush_Accent1}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  Scrollbar  -->
        <!--  This is kinda the track of the scrollbar  -->
        <Style x:Key="ScrollBarPageButton" TargetType="{x:Type RepeatButton}">
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="OverridesDefaultStyle" Value="true" />
            <Setter Property="IsTabStop" Value="false" />
            <Setter Property="Focusable" Value="false" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type RepeatButton}">

                        <!--  Color of the Track  -->
                        <Border Background="Transparent" />

                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  Thumb  -->
        <Style x:Key="ScrollBarThumb" TargetType="{x:Type Thumb}">
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Background" Value="{StaticResource Brush_Layer9}" />
            <Setter Property="OverridesDefaultStyle" Value="true" />
            <Setter Property="IsTabStop" Value="false" />
            <Setter Property="Focusable" Value="false" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Border
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            CornerRadius="5" />

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter Property="Background" Value="{StaticResource Brush_Layer10}" />
                            </Trigger>
                            <Trigger Property="IsDragging" Value="true">
                                <Setter Property="Background" Value="{StaticResource Brush_Layer9}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  Vertical Scrollbar  -->
        <ControlTemplate x:Key="VerticalScrollBar" TargetType="{x:Type ScrollBar}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition MaxHeight="18" />
                    <RowDefinition Height="0.00001*" />
                    <RowDefinition MaxHeight="18" />
                </Grid.RowDefinitions>

                <!--  Background Color"  -->
                <Border
                    Grid.RowSpan="3"
                    Background="Transparent"
                    CornerRadius="2" />

                <!--  RowSpan 3 so it takes also the space of the upper and the lower Repeat-Button  -->
                <Track
                    x:Name="PART_Track"
                    Grid.Row="0"
                    Grid.RowSpan="3"
                    IsDirectionReversed="true">

                    <Track.Thumb>
                        <Thumb Style="{StaticResource ScrollBarThumb}" />
                    </Track.Thumb>
                </Track>
            </Grid>
        </ControlTemplate>

        <!--  Horizontal Scrollbar  -->
        <ControlTemplate x:Key="HorizontalScrollBar" TargetType="{x:Type ScrollBar}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition MaxWidth="18" />
                    <ColumnDefinition Width="0.00001*" />
                    <ColumnDefinition MaxWidth="18" />
                </Grid.ColumnDefinitions>

                <!--  Background Color  -->
                <Border
                    Grid.ColumnSpan="3"
                    Background="Transparent"
                    CornerRadius="2" />

                <!--  ColumnSpan 3 so it takes also the space of the left and the right Repeat-Button  -->
                <Track
                    x:Name="PART_Track"
                    Grid.Column="0"
                    Grid.ColumnSpan="3"
                    IsDirectionReversed="False">

                    <Track.Thumb>
                        <Thumb Style="{StaticResource ScrollBarThumb}" />
                    </Track.Thumb>
                </Track>
            </Grid>
        </ControlTemplate>

        <!--  General Scrollbar  -->
        <Style x:Key="customscrollbar" TargetType="{x:Type ScrollBar}">
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="OverridesDefaultStyle" Value="true" />
            <Style.Triggers>

                <!--  Horizontal Scrollbar  -->
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Width" Value="Auto" />
                    <Setter Property="Height" Value="15" />
                    <Setter Property="Template" Value="{StaticResource HorizontalScrollBar}" />
                </Trigger>

                <!--  Vertical Scrollbar  -->
                <Trigger Property="Orientation" Value="Vertical">
                    <Setter Property="Width" Value="15" />
                    <Setter Property="Height" Value="Auto" />
                    <Setter Property="Template" Value="{StaticResource VerticalScrollBar}" />

                </Trigger>
            </Style.Triggers>
        </Style>
    </Application.Resources>
</Application>
